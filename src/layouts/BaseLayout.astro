---
import '../global.css';
export interface Props {
  title: string;
  description?: string;
  fontUrl?: string;
  themeColor?: string;
  ogImage?: string;
}
const {
  title,
  description = 'Expert personal training — real programming, real results.',
  fontUrl,
  themeColor = '#000000',
  ogImage = '/images/shared/photo-1534438327276-14e5300c3a48-1024.webp',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>html,body{overflow-x:hidden}</style>
    <meta name="description" content={description} />
    <meta name="theme-color" content={themeColor} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {fontUrl && (
      <>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link rel="stylesheet" href={fontUrl} />
      </>
    )}
    <slot name="head" />
    <script src="/template-topheader.js" defer></script>
    <style>
      html { scroll-padding-top: 40px !important; }
      body { padding-top: 36px !important; }
      body > #dcrader-topheader, body > [data-dcrader-topheader] { padding-top: 0 !important; margin-top: -36px !important; }
    </style>
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[9999] focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:rounded focus:shadow-lg"
    >
      Skip to main content
    </a>
    <slot />
  </body>
</html>
