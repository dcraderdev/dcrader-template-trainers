---
// v1: Strength Elite hero — heavy, dark, barbell imagery, athletic typography
import ResponsiveImage from '../ResponsiveImage.astro';
export interface Props {
  coach: any;
  heroImg: string;
}
const { coach, heroImg } = Astro.props;
---
<section
  style="position:relative;min-height:100vh;display:flex;flex-direction:column;justify-content:flex-end;padding-top:7rem;padding-bottom:5rem;overflow:hidden;background:#000;"
  aria-labelledby="hero-h1"
>
  <ResponsiveImage
    src={heroImg}
    alt="Heavy iron barbells loaded with calibrated plates on a competition platform"
    sizes="100vw"
    loading="eager"
    decoding="async"
    fetchpriority="high"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;filter:grayscale(0.4) contrast(1.1);"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(to top,#000 35%,rgba(0,0,0,.85) 60%,rgba(0,0,0,.35) 100%);"></div>

  <!-- Plate stack visual rail (left) — barbell imagery treatment -->
  <div aria-hidden="true" class="hide-mobile" style="position:absolute;left:0;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;gap:.5rem;padding:1rem;">
    {[{w:'45',c:'#dc2626'},{w:'35',c:'#fbbf24'},{w:'25',c:'#16a34a'},{w:'10',c:'#fff'}].map(p => (
      <div style={`background:${p.c};color:#000;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.05rem;letter-spacing:.05em;padding:.45rem .9rem;border-radius:999px;border:3px solid #000;box-shadow:0 6px 16px rgba(0,0,0,.5);`}>{p.w} LB</div>
    ))}
  </div>

  <div style="position:relative;z-index:10;max-width:1280px;margin:0 auto;padding:0 1.5rem;width:100%;">
    <!-- Heavy plate-stack callout instead of subtle eyebrow -->
    <div style="display:inline-flex;align-items:center;gap:.75rem;background:rgba(220,38,38,.18);border:2px solid #dc2626;padding:.5rem 1rem;margin-bottom:1.25rem;">
      <span aria-hidden="true" style="display:inline-block;width:14px;height:14px;background:#dc2626;border-radius:50%;"></span>
      <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:.7rem;letter-spacing:.45em;color:#fff;text-transform:uppercase;margin:0;">San Diego · NSCA-CSCS · Loaded Daily</p>
    </div>

    <h1 id="hero-h1" style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:clamp(4rem,13vw,11rem);line-height:.88;color:#fff;text-transform:uppercase;margin-bottom:1.25rem;text-shadow:0 8px 24px rgba(0,0,0,.7);">
      HEAVY.<br/><span style="color:#dc2626;">HEAVIER.</span><br/>HEAVIEST.
    </h1>

    <!-- Bar-weight breakdown (athletic typography treatment) -->
    <div style="display:flex;align-items:stretch;gap:0;border-top:4px solid #dc2626;border-bottom:1px solid rgba(255,255,255,.15);padding:1rem 0;margin-bottom:1.75rem;max-width:48rem;">
      {[
        {label:'Bar',value:'45'},
        {label:'+ Plates',value:'4 × 45'},
        {label:'= Total',value:'225 LB'},
        {label:'Per Side',value:'Stacked'},
      ].map((s,i) => (
        <div style={`flex:1;padding:0 1rem;border-right:${i<3?'1px solid rgba(255,255,255,.12)':'none'};`}>
          <p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.65rem;letter-spacing:.25em;color:#9ca3af;text-transform:uppercase;margin:0 0 .25rem;">{s.label}</p>
          <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.4rem;color:#fff;text-transform:uppercase;margin:0;line-height:1;">{s.value}</p>
        </div>
      ))}
    </div>

    <p style="font-family:'Barlow',sans-serif;font-size:1.1rem;color:#d1d5db;max-width:36rem;line-height:1.7;margin-bottom:2.25rem;">{coach.tagline}</p>

    <div style="display:flex;gap:1rem;flex-wrap:wrap;">
      <a href="#booking" style="background:#dc2626;color:#fff;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.25rem;letter-spacing:.15em;text-transform:uppercase;text-decoration:none;padding:1rem 2.5rem;display:inline-block;border:2px solid #dc2626;">CLAIM FREE INTAKE SESSION</a>
      <a href="#calc" style="border:2px solid rgba(255,255,255,.3);color:#fff;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.25rem;letter-spacing:.15em;text-transform:uppercase;text-decoration:none;padding:1rem 2.5rem;display:inline-block;">CALCULATE MY 1RM →</a>
    </div>
  </div>
</section>
