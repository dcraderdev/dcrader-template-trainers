---
// v5: Program tiers hero — membership/program cards with prices AS the hero
export interface Props {
  coach: any;
}
const { coach } = Astro.props;
---
<section style="position:relative;background:#000;padding:7rem 1.5rem 4rem;overflow:hidden;" aria-labelledby="hero-h1">
  <!-- Diagonal orange accent backdrop -->
  <div aria-hidden="true" style="position:absolute;inset:0;background:radial-gradient(circle at 80% 20%,rgba(234,88,12,.18) 0%,transparent 55%),radial-gradient(circle at 10% 90%,rgba(234,88,12,.12) 0%,transparent 50%),#000;"></div>

  <div style="position:relative;z-index:1;max-width:1200px;margin:0 auto;">
    <!-- Heading -->
    <div style="text-align:center;max-width:42rem;margin:0 auto 2.25rem;">
      <span style="display:inline-block;background:#EA580C;color:#000;padding:.4rem .85rem;font-family:'Oswald',sans-serif;font-weight:700;font-size:.7rem;letter-spacing:.22em;text-transform:uppercase;margin-bottom:1.25rem;clip-path:polygon(6px 0,100% 0,calc(100% - 6px) 100%,0 100%);">
        Pick Your Tribe Tier
      </span>
      <h1 id="hero-h1" class="oswald" style="font-family:'Oswald',sans-serif;font-size:clamp(2.75rem,6vw,5rem);font-weight:700;text-transform:uppercase;color:#fff;line-height:.95;letter-spacing:.02em;margin:0 0 1rem;">
        Three Tiers.<br/><span style="color:#EA580C;">One Tribe.</span>
      </h1>
      <p style="font-family:'Inter',system-ui,sans-serif;color:#bbb;font-size:1.05rem;line-height:1.65;margin:0;">{coach.tagline}</p>
    </div>

    <!-- Program tier cards (the hero) -->
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;margin-bottom:2rem;">
      {(coach.pricing || []).map((tier: any) => (
        <article style={`background:#0f0f0f;border:${tier.popular ? '2px solid #EA580C' : '1px solid #2a2a2a'};padding:2rem 1.6rem;position:relative;${tier.popular ? 'box-shadow:0 18px 50px rgba(234,88,12,.25);transform:translateY(-6px);' : ''}`}>
          {tier.popular && (
            <span class="oswald" style="position:absolute;top:0;right:1rem;transform:translateY(-50%);background:#EA580C;color:#000;font-family:'Oswald',sans-serif;font-weight:700;font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;padding:.3rem .8rem;">Most Joined</span>
          )}
          <p class="oswald" style="font-family:'Oswald',sans-serif;font-size:.8rem;letter-spacing:.25em;color:#999;text-transform:uppercase;font-weight:700;margin:0 0 .5rem;">{tier.name}</p>
          <p class="oswald" style="font-family:'Oswald',sans-serif;font-size:3.5rem;font-weight:700;color:#fff;line-height:1;margin:0;">
            ${tier.price}<span style="font-size:1rem;color:#999;font-weight:400;">/mo</span>
          </p>
          <p style="font-family:'Inter',system-ui,sans-serif;font-size:.75rem;color:#999;margin:.4rem 0 1.25rem;text-transform:uppercase;letter-spacing:.1em;">No contract · Cancel anytime</p>
          <ul style="list-style:none;padding:0;margin:0 0 1.5rem;display:flex;flex-direction:column;gap:.55rem;">
            {(tier.features || []).slice(0, 5).map((f: string) => (
              <li style="display:flex;align-items:flex-start;gap:.55rem;font-family:'Inter',system-ui,sans-serif;font-size:.82rem;color:#ccc;line-height:1.4;">
                <span aria-hidden="true" style="color:#EA580C;font-weight:700;flex-shrink:0;margin-top:.05rem;">▶</span>{f}
              </li>
            ))}
          </ul>
          <a href="#join" class="oswald" style={`display:block;text-align:center;font-family:'Oswald',sans-serif;font-weight:700;font-size:.85rem;letter-spacing:.18em;text-transform:uppercase;text-decoration:none;padding:.9rem;${tier.popular ? 'background:#EA580C;color:#000;' : 'background:transparent;color:#fff;border:1px solid #444;'}`}>
            Claim {tier.name}
          </a>
        </article>
      ))}
    </div>

    <p style="text-align:center;font-family:'Inter',system-ui,sans-serif;color:#999;font-size:.85rem;margin:0;">
      Or <a href="#join" style="color:#EA580C;text-decoration:none;font-weight:600;">drop in for one free class</a> · Bayfront Park · Miami
    </p>
  </div>
</section>
