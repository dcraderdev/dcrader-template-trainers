---
/**
 * FocusTrap — keyboard focus containment for modals, dialogs, drawers.
 *
 * Behavior when active (data-active="true"):
 *  - Tab / Shift+Tab cycle focus within the trap.
 *  - Esc fires a "a11y:focustrap-close" CustomEvent on the trap element.
 *  - On activation, focus moves to first focusable child (or [data-autofocus]).
 *  - On deactivation, focus returns to the previously-focused element.
 *
 * Activation pattern (from parent):
 *   const trap = document.getElementById('my-trap');
 *   trap.dataset.active = 'true';   // open
 *   trap.dataset.active = 'false';  // close
 *
 * Listen for Esc:
 *   trap.addEventListener('a11y:focustrap-close', () => closeModal());
 *
 * Vanilla implementation — no React dependency. Works in Astro islands too.
 */
interface Props {
  id?: string;
  /** Initial active state. Defaults to false; toggle via dataset.active. */
  active?: boolean;
  /** Element role. Default: dialog. Pass "" for no role (e.g. menus). */
  role?: string;
  /** aria-label for the trap region. */
  label?: string;
  /** id of element that labels the trap (aria-labelledby). */
  labelledby?: string;
  /** id of element that describes the trap (aria-describedby). */
  describedby?: string;
  /** Extra class names. */
  class?: string;
}

const {
  id,
  active = false,
  role = 'dialog',
  label,
  labelledby,
  describedby,
  class: className = '',
} = Astro.props;
---

<div
  id={id}
  class={`a11y-focus-trap ${className}`.trim()}
  data-a11y-focus-trap
  data-active={String(active)}
  role={role || undefined}
  aria-modal={role === 'dialog' ? 'true' : undefined}
  aria-label={label}
  aria-labelledby={labelledby}
  aria-describedby={describedby}
>
  <slot />
</div>

<script>
  const FOCUSABLE = [
    'a[href]',
    'area[href]',
    'button:not([disabled])',
    'input:not([disabled]):not([type="hidden"])',
    'select:not([disabled])',
    'textarea:not([disabled])',
    'iframe',
    'object',
    'embed',
    '[tabindex]:not([tabindex="-1"])',
    '[contenteditable="true"]',
  ].join(',');

  type TrapState = {
    el: HTMLElement;
    prevFocus: Element | null;
    keyHandler: (e: KeyboardEvent) => void;
  };

  const traps = new WeakMap<HTMLElement, TrapState>();

  function getFocusable(root: HTMLElement): HTMLElement[] {
    return Array.from(root.querySelectorAll<HTMLElement>(FOCUSABLE)).filter(
      (el) =>
        !el.hasAttribute('inert') &&
        el.offsetParent !== null &&
        getComputedStyle(el).visibility !== 'hidden',
    );
  }

  function activate(el: HTMLElement) {
    if (traps.has(el)) return;
    const prevFocus = document.activeElement;

    const keyHandler = (e: KeyboardEvent) => {
      if (el.dataset.active !== 'true') return;
      if (e.key === 'Escape') {
        e.stopPropagation();
        el.dispatchEvent(new CustomEvent('a11y:focustrap-close', { bubbles: true }));
        return;
      }
      if (e.key !== 'Tab') return;
      const items = getFocusable(el);
      if (items.length === 0) {
        e.preventDefault();
        el.focus();
        return;
      }
      const first = items[0];
      const last = items[items.length - 1];
      const current = document.activeElement as HTMLElement | null;
      if (e.shiftKey && current === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && current === last) {
        e.preventDefault();
        first.focus();
      }
    };

    document.addEventListener('keydown', keyHandler, true);
    traps.set(el, { el, prevFocus, keyHandler });

    // Move focus inside
    requestAnimationFrame(() => {
      const auto = el.querySelector<HTMLElement>('[data-autofocus]');
      const items = getFocusable(el);
      (auto ?? items[0] ?? el).focus();
    });
  }

  function deactivate(el: HTMLElement) {
    const state = traps.get(el);
    if (!state) return;
    document.removeEventListener('keydown', state.keyHandler, true);
    traps.delete(el);
    if (state.prevFocus instanceof HTMLElement) {
      state.prevFocus.focus();
    }
  }

  function sync(el: HTMLElement) {
    if (el.dataset.active === 'true') activate(el);
    else deactivate(el);
  }

  function init(el: HTMLElement) {
    if (!el.hasAttribute('tabindex')) el.setAttribute('tabindex', '-1');
    sync(el);
    const observer = new MutationObserver((muts) => {
      for (const m of muts) {
        if (m.type === 'attributes' && m.attributeName === 'data-active') sync(el);
      }
    });
    observer.observe(el, { attributes: true });
  }

  document
    .querySelectorAll<HTMLElement>('[data-a11y-focus-trap]')
    .forEach((el) => init(el));
</script>

<style>
  .a11y-focus-trap[data-active='false'] {
    display: none;
  }
  .a11y-focus-trap:focus {
    outline: none;
  }
</style>
