---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResponsiveImage from '../components/ResponsiveImage.astro';
import { coach } from '../data/v1-coach';
const HERO = '/images/shared/photo-1534438327276-14e5300c3a48';
---
<BaseLayout
  title="Steel Athletics — PR Or Not. No Middle Ground."
  description="Elite powerlifting and strength coaching in San Diego. Science-driven. Relentless. Book your free intake session."
  fontUrl="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@300;400;500&display=swap"
  themeColor="#000000"
  ogImage="/images/shared/photo-1534438327276-14e5300c3a48-1920.webp"
>
<Fragment slot="head">
  <link
    rel="preload"
    as="image"
    fetchpriority="high"
    type="image/avif"
    imagesrcset={`${HERO}-320.avif 320w, ${HERO}-640.avif 640w, ${HERO}-1024.avif 1024w, ${HERO}-1920.avif 1920w`}
    imagesizes="100vw"
  />
</Fragment>

<style is:inline>
  .pr-ticker {
    display: flex;
    gap: 3rem;
    animation: ticker 28s linear infinite;
    white-space: nowrap;
  }
  @keyframes ticker {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .calc-input::-webkit-inner-spin-button,
  .calc-input::-webkit-outer-spin-button { -webkit-appearance: none; }
  .calc-input { -moz-appearance: textfield; }
</style>

<!-- NAV -->
<nav aria-label="Main navigation" style="position:fixed;top:0;width:100%;z-index:50;background:#000;border-bottom:2px solid #dc2626;">
  <div style="max-width:1280px;margin:0 auto;padding:0 1.5rem;display:flex;align-items:center;justify-content:space-between;height:56px;">
    <span style="font-family:'Barlow Condensed',sans-serif;font-size:1.5rem;font-weight:900;letter-spacing:.2em;color:#fff;text-transform:uppercase;">STEEL ATHLETICS</span>
    <div style="display:flex;align-items:center;gap:2rem;">
      <a href="#programs" style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.75rem;letter-spacing:.25em;color:#9ca3af;text-transform:uppercase;text-decoration:none;">Programs</a>
      <a href="#calc" style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.75rem;letter-spacing:.25em;color:#9ca3af;text-transform:uppercase;text-decoration:none;">1RM Calc</a>
      <a href="#pricing" style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.75rem;letter-spacing:.25em;color:#9ca3af;text-transform:uppercase;text-decoration:none;">Pricing</a>
      <a href="#booking" style="background:#dc2626;color:#fff;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:.75rem;letter-spacing:.2em;text-transform:uppercase;text-decoration:none;padding:.5rem 1.25rem;">BOOK FREE INTAKE</a>
    </div>
  </div>
</nav>

<main id="main-content">

<!-- ───── HERO ───── -->
<section style="position:relative;min-height:100vh;display:flex;flex-direction:column;justify-content:flex-end;padding-top:7rem;padding-bottom:5rem;overflow:hidden;" aria-labelledby="hero-h1">
  <ResponsiveImage
    src={HERO}
    alt="Heavy iron barbells under dramatic gym lighting"
    sizes="100vw"
    loading="eager"
    decoding="async"
    fetchpriority="high"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(to top,#000 40%,rgba(0,0,0,.7) 70%,rgba(0,0,0,.3) 100%);"></div>
  <!-- Red diagonal slash accent -->
  <div style="position:absolute;top:0;right:0;width:40%;height:100%;background:linear-gradient(135deg,transparent 50%,rgba(220,38,38,.08) 50%);pointer-events:none;"></div>

  <div style="position:relative;z-index:10;max-width:1280px;margin:0 auto;padding:0 1.5rem;width:100%;">
    <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:.7rem;letter-spacing:.5em;color:#dc2626;text-transform:uppercase;margin-bottom:1rem;">San Diego · Est. 2012 · NSCA-CSCS Certified</p>
    <h1 id="hero-h1" style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:clamp(4rem,12vw,10rem);line-height:.92;color:#fff;text-transform:uppercase;margin-bottom:1.5rem;">
      PR<br/><span style="color:#dc2626;">OR</span><br/>NOT.
    </h1>
    <div style="width:4rem;height:3px;background:#dc2626;margin-bottom:1.5rem;"></div>
    <p style="font-family:'Barlow',sans-serif;font-size:1.1rem;color:#d1d5db;max-width:36rem;line-height:1.7;margin-bottom:2.5rem;">{coach.tagline}</p>
    <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:3rem;">
      <a href="#booking" style="background:#dc2626;color:#fff;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.25rem;letter-spacing:.15em;text-transform:uppercase;text-decoration:none;padding:1rem 2.5rem;display:inline-block;">CLAIM FREE INTAKE SESSION</a>
      <a href="#calc" style="border:2px solid rgba(255,255,255,.3);color:#fff;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.25rem;letter-spacing:.15em;text-transform:uppercase;text-decoration:none;padding:1rem 2.5rem;display:inline-block;">CALCULATE MY 1RM →</a>
    </div>
    <!-- Lift Log card — credentialed coaching, not a stats grid -->
    <div style="border-top:1px solid rgba(255,255,255,.1);padding-top:2rem;display:grid;grid-template-columns:auto 1fr;gap:1.5rem;align-items:center;">
      <div aria-hidden="true" style="border:2px solid #dc2626;padding:.75rem 1rem;text-align:center;">
        <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:.65rem;letter-spacing:.3em;color:#dc2626;text-transform:uppercase;margin:0 0 .25rem;">Coach</p>
        <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.5rem;color:#fff;line-height:1;margin:0;">CSCS</p>
        <p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.7rem;letter-spacing:.15em;color:#9ca3af;text-transform:uppercase;margin:.25rem 0 0;">NASM · USAW L2</p>
      </div>
      <div>
        <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:.7rem;letter-spacing:.3em;color:#dc2626;text-transform:uppercase;margin-bottom:.5rem;">2012 National Champion · Coaching since 2013</p>
        <p style="font-family:'Barlow',sans-serif;font-size:.95rem;color:#e4e4e7;line-height:1.6;margin:0;">Programming hand-built off your last training block. No copy-paste templates. No filler sets.</p>
      </div>
    </div>
  </div>
</section>

<!-- ───── PR TICKER ───── -->
<div style="background:#dc2626;padding:.75rem 0;overflow:hidden;" aria-label="Recent client personal records">
  <div class="pr-ticker">
    {[
      "Jake M. — 405 lb Squat PR",
      "Derek T. — 315 lb Bench Press PR",
      "Chris W. — 510 lb Deadlift PR",
      "Ryan B. — 225 lb Overhead Press PR",
      "Kevin D. — 455 lb Squat PR",
      "Mike R. — National Qualifier",
      "Tom S. — 600 lb Deadlift PR",
      "Jake M. — 405 lb Squat PR",
      "Derek T. — 315 lb Bench Press PR",
      "Chris W. — 510 lb Deadlift PR",
      "Ryan B. — 225 lb Overhead Press PR",
      "Kevin D. — 455 lb Squat PR",
      "Mike R. — National Qualifier",
      "Tom S. — 600 lb Deadlift PR",
    ].map(pr => (
      <span style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1rem;letter-spacing:.1em;color:#fff;text-transform:uppercase;flex-shrink:0;">
        ✦ {pr}
      </span>
    ))}
  </div>
</div>

<!-- ───── 1RM CALCULATOR ───── -->
<section id="calc" style="background:#09090b;padding:5rem 0;" aria-labelledby="calc-heading">
  <div style="max-width:760px;margin:0 auto;padding:0 1.5rem;">
    <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:.75rem;letter-spacing:.4em;color:#dc2626;text-transform:uppercase;margin-bottom:.75rem;">Training Tool</p>
    <h2 id="calc-heading" style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:3.5rem;color:#fff;text-transform:uppercase;margin-bottom:.5rem;">1 REP MAX CALCULATOR</h2>
    <p style="font-family:'Barlow',sans-serif;color:#6b7280;margin-bottom:2.5rem;">Enter the weight and reps from your best set. We'll calculate your estimated 1RM and training percentages using the Epley formula.</p>

    <div style="border:2px solid #27272a;background:#18181b;padding:2.5rem;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:1.5rem;">
        <div>
          <label for="calc-weight" style="display:block;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.75rem;letter-spacing:.2em;color:#9ca3af;text-transform:uppercase;margin-bottom:.5rem;">Weight Lifted (lbs) *</label>
          <input type="number" id="calc-weight" class="calc-input" min="1" max="2000" placeholder="225"
            style="width:100%;background:#09090b;border:2px solid #3f3f46;color:#fff;padding:.875rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1.5rem;font-weight:700;outline:none;box-sizing:border-box;" />
        </div>
        <div>
          <label for="calc-reps" style="display:block;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.75rem;letter-spacing:.2em;color:#9ca3af;text-transform:uppercase;margin-bottom:.5rem;">Reps Completed *</label>
          <input type="number" id="calc-reps" class="calc-input" min="1" max="15" placeholder="5"
            style="width:100%;background:#09090b;border:2px solid #3f3f46;color:#fff;padding:.875rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1.5rem;font-weight:700;outline:none;box-sizing:border-box;" />
        </div>
      </div>
      <button id="calc-btn" onclick="calcRM()"
        style="width:100%;background:#dc2626;color:#fff;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.5rem;letter-spacing:.2em;text-transform:uppercase;border:none;padding:1.1rem;cursor:pointer;">
        CALCULATE MY 1RM
      </button>

      <div id="rm-result" style="display:none;margin-top:2rem;border-top:1px solid #27272a;padding-top:2rem;">
        <p style="font-family:'Barlow',sans-serif;font-size:.8rem;letter-spacing:.2em;color:#6b7280;text-transform:uppercase;text-align:center;">Estimated 1 Rep Max</p>
        <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:6rem;color:#dc2626;text-align:center;line-height:1;margin:.5rem 0;"><span id="rm-value">—</span> <span style="font-size:2rem;color:#71717a;">lbs</span></p>
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:.75rem;margin-top:1.5rem;">
          {[['50%','p50'],['65%','p65'],['75%','p75'],['85%','p85'],['90%','p90'],['95%','p95'],['97%','p97'],['100%','p100']].map(([pct,id]) => (
            <div style="background:#09090b;border:1px solid #27272a;padding:.875rem .5rem;text-align:center;">
              <p style="font-family:'Barlow',sans-serif;font-size:.7rem;color:#6b7280;text-transform:uppercase;">{pct}</p>
              <p id={id} style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.25rem;color:#fff;margin-top:.25rem;">—</p>
            </div>
          ))}
        </div>
        <p style="font-family:'Barlow',sans-serif;font-size:.75rem;color:#52525b;margin-top:1rem;text-align:center;">Epley formula. Use as a training guide, not a competition predictor.</p>
      </div>
    </div>
  </div>
</section>

<!-- ───── TRANSFORMATIONS ───── -->
<section id="transformations" style="background:#000;padding:5rem 0;" aria-labelledby="trans-h2">
  <div style="max-width:1280px;margin:0 auto;padding:0 1.5rem;">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:3rem;border-bottom:2px solid #dc2626;padding-bottom:1rem;">
      <div>
        <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:.75rem;letter-spacing:.4em;color:#dc2626;text-transform:uppercase;margin-bottom:.5rem;">Client Results</p>
        <h2 id="trans-h2" style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:3rem;color:#fff;text-transform:uppercase;line-height:1;">TRANSFORMATIONS</h2>
      </div>
      <p style="font-family:'Barlow',sans-serif;color:#6b7280;font-size:.875rem;max-width:16rem;text-align:right;">Real athletes. Real programming. Verified results.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:2px;background:#dc2626;">
      {coach.transformations.map(t => (
        <article style="background:#09090b;padding:0;">
          <div style="display:grid;grid-template-columns:1fr 1fr;position:relative;">
            <div style="position:relative;">
              <img loading="lazy" decoding="async" src={t.beforeImg} alt={`${t.name} before — training start`} style="width:100%;height:14rem;object-fit:cover;object-position:top;display:block;" />
              <span style="position:absolute;top:.5rem;left:.5rem;background:rgba(0,0,0,.85);color:#9ca3af;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.65rem;letter-spacing:.15em;text-transform:uppercase;padding:.25rem .5rem;">BEFORE</span>
            </div>
            <div style="position:relative;">
              <img loading="lazy" decoding="async" src={t.afterImg} alt={`${t.name} after — ${t.result}`} style="width:100%;height:14rem;object-fit:cover;object-position:top;display:block;" />
              <span style="position:absolute;top:.5rem;right:.5rem;background:#dc2626;color:#fff;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:.65rem;letter-spacing:.15em;text-transform:uppercase;padding:.25rem .5rem;">AFTER</span>
            </div>
          </div>
          <div style="padding:1.25rem;border-top:2px solid #dc2626;">
            <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.25rem;color:#fff;text-transform:uppercase;">{t.name}</p>
            <p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1rem;color:#dc2626;margin:.25rem 0;">{t.result}</p>
            <p style="font-family:'Barlow',sans-serif;font-size:.8rem;color:#6b7280;font-style:italic;">"{t.quote}"</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- ───── PROGRAMS ───── -->
<section id="programs" style="background:#09090b;padding:5rem 0;" aria-labelledby="programs-h2">
  <div style="max-width:1280px;margin:0 auto;padding:0 1.5rem;">
    <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:.75rem;letter-spacing:.4em;color:#dc2626;text-transform:uppercase;margin-bottom:.75rem;">Systems</p>
    <h2 id="programs-h2" style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:3.5rem;color:#fff;text-transform:uppercase;margin-bottom:3rem;">PROGRAMMING THAT PERFORMS</h2>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:2px;background:#27272a;">
      {coach.programs.map((prog, i) => (
        <div style={`background:#000;padding:2.5rem;border-top:4px solid ${i===1?'#dc2626':'#27272a'};`}>
          <p style="font-size:2.5rem;margin-bottom:1.25rem;">{prog.icon}</p>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:2rem;color:#fff;text-transform:uppercase;margin-bottom:.75rem;">{prog.name}</h3>
          <p style="font-family:'Barlow',sans-serif;font-size:.875rem;color:#6b7280;line-height:1.7;margin-bottom:1.5rem;">{prog.description}</p>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.625rem;">
            {prog.features.map(f => (
              <li style="display:flex;align-items:flex-start;gap:.625rem;font-family:'Barlow',sans-serif;font-size:.875rem;color:#d4d4d8;">
                <span style="color:#dc2626;font-weight:900;margin-top:2px;flex-shrink:0;">▶</span>{f}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ───── PRICING ───── -->
<section id="pricing" style="background:#000;padding:5rem 0;" aria-labelledby="pricing-h2">
  <div style="max-width:1280px;margin:0 auto;padding:0 1.5rem;">
    <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:.75rem;letter-spacing:.4em;color:#dc2626;text-transform:uppercase;margin-bottom:.75rem;">Investment</p>
    <h2 id="pricing-h2" style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:3.5rem;color:#fff;text-transform:uppercase;margin-bottom:.5rem;">CHOOSE YOUR LEVEL</h2>
    <p style="font-family:'Barlow',sans-serif;color:#6b7280;margin-bottom:3rem;">No contracts. First session free. Cancel anytime.</p>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;">
      {coach.pricing.map(tier => (
        <div style={`position:relative;padding:2.5rem;border:2px solid ${tier.popular?'#dc2626':'#27272a'};background:${tier.popular?'rgba(220,38,38,.05)':'#09090b'};`}>
          {tier.popular && <span style="position:absolute;top:-1px;left:50%;transform:translateX(-50%);background:#dc2626;color:#fff;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;padding:.25rem 1rem;">MOST POPULAR</span>}
          <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1rem;letter-spacing:.2em;color:#6b7280;text-transform:uppercase;">{tier.name}</p>
          <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:4.5rem;color:#fff;line-height:1;margin:.5rem 0;">${tier.price}<span style="font-size:1.25rem;color:#71717a;font-weight:400;">/mo</span></p>
          <div style="border-top:1px solid #27272a;margin:1.5rem 0;padding-top:1.5rem;">
            <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.875rem;">
              {tier.features.map(f => (
                <li style="display:flex;align-items:flex-start;gap:.75rem;font-family:'Barlow',sans-serif;font-size:.875rem;color:#d4d4d8;">
                  <span style="color:#dc2626;font-weight:900;flex-shrink:0;margin-top:2px;">✓</span>{f}
                </li>
              ))}
            </ul>
          </div>
          <a href="#booking" style={`display:block;text-align:center;padding:.875rem;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.25rem;letter-spacing:.15em;text-transform:uppercase;text-decoration:none;background:${tier.popular?'#dc2626':'transparent'};color:#fff;border:2px solid ${tier.popular?'#dc2626':'#3f3f46'};`}>
            GET STARTED
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ───── COACH BIO ───── -->
<section id="coach" style="background:#09090b;padding:5rem 0;" aria-labelledby="coach-h2">
  <div style="max-width:1280px;margin:0 auto;padding:0 1.5rem;display:grid;grid-template-columns:5fr 7fr;gap:4rem;align-items:start;">
    <div style="position:relative;">
      <img loading="lazy" decoding="async" src={coach.photo} alt={`${coach.name} — ${coach.title}`} style="width:100%;aspect-ratio:3/4;object-fit:cover;display:block;" />
      <div style="position:absolute;bottom:0;left:0;right:0;background:linear-gradient(to top,rgba(0,0,0,.95),transparent);padding:1.5rem;">
        <div style="display:flex;flex-wrap:wrap;gap:.375rem;">
          {coach.certifications.map(c => (
            <span style="background:#dc2626;color:#fff;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:.65rem;letter-spacing:.1em;text-transform:uppercase;padding:.25rem .625rem;">{c}</span>
          ))}
        </div>
      </div>
    </div>
    <div>
      <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:.75rem;letter-spacing:.4em;color:#dc2626;text-transform:uppercase;margin-bottom:.75rem;">Your Coach</p>
      <h2 id="coach-h2" style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:4rem;color:#fff;text-transform:uppercase;line-height:.95;margin-bottom:.5rem;">{coach.name}</h2>
      <p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.5rem;color:#dc2626;text-transform:uppercase;letter-spacing:.1em;margin-bottom:2rem;">{coach.title}</p>
      <p style="font-family:'Barlow',sans-serif;font-size:1.1rem;color:#e4e4e7;line-height:1.7;margin-bottom:1rem;">{coach.bio}</p>
      <p style="font-family:'Barlow',sans-serif;font-size:.95rem;color:#71717a;line-height:1.7;margin-bottom:2.5rem;">{coach.bioExtended}</p>
      <!-- Featured client transformation showcase — story, not numbers -->
      <div style="border:2px solid #27272a;background:#0a0a0a;padding:0;">
        <div style="background:#dc2626;padding:.75rem 1.25rem;display:flex;justify-content:space-between;align-items:center;">
          <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:.7rem;letter-spacing:.3em;color:#fff;text-transform:uppercase;margin:0;">Featured Client · Marcus on Jake M.</p>
          <p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.7rem;letter-spacing:.2em;color:#fecaca;text-transform:uppercase;margin:0;">14 months</p>
        </div>
        <div style="padding:1.25rem;">
          <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.5rem;color:#fff;text-transform:uppercase;line-height:1.1;margin-bottom:.75rem;">
            "He walked in scared of the bar. He walked out a state-record holder."
          </p>
          <p style="font-family:'Barlow',sans-serif;font-size:.95rem;color:#d4d4d8;line-height:1.65;margin-bottom:.75rem;">
            Jake came in after two failed cuts and a torn rotator from bad cues at a chain gym. We spent the first eight weeks rebuilding his bracing pattern and undoing the damage. Then we ran a 16-week conjugate block. By month ten he was hitting triples at his old PR.
          </p>
          <p style="font-family:'Barlow',sans-serif;font-size:.95rem;color:#d4d4d8;line-height:1.65;margin-bottom:1rem;">
            At his first sanctioned meet he pulled a 600 deadlift on his second attempt — clean lockout, no belt slip. The kid cried in the warmup room.
          </p>
          <p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.75rem;letter-spacing:.25em;color:#dc2626;text-transform:uppercase;margin:0;">— Marcus Steel, head coach</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ───── TESTIMONIALS ───── -->
<section id="testimonials" style="background:#000;padding:5rem 0;" aria-labelledby="test-h2">
  <div style="max-width:1280px;margin:0 auto;padding:0 1.5rem;">
    <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:.75rem;letter-spacing:.4em;color:#dc2626;text-transform:uppercase;margin-bottom:.75rem;">Social Proof</p>
    <h2 id="test-h2" style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:3.5rem;color:#fff;text-transform:uppercase;margin-bottom:3rem;">THE PROOF IS IN THE PR</h2>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:2px;background:#27272a;">
      {coach.testimonials.map(t => (
        <blockquote style="background:#09090b;padding:2.5rem;margin:0;">
          <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:4rem;color:#dc2626;line-height:.8;margin-bottom:1rem;" aria-hidden="true">"</p>
          <p style="font-family:'Barlow',sans-serif;font-size:.9rem;color:#d4d4d8;line-height:1.8;margin-bottom:1.5rem;">{t.text}</p>
          <footer style="display:flex;align-items:flex-end;justify-content:space-between;border-top:1px solid #27272a;padding-top:1rem;">
            <div>
              <cite style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.25rem;color:#fff;font-style:normal;text-transform:uppercase;">{t.name}</cite>
              <p style="font-family:'Barlow',sans-serif;font-size:.75rem;color:#6b7280;margin-top:.125rem;">{t.details}</p>
            </div>
            <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:2.5rem;color:#dc2626;">{t.result}</p>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>

<!-- ───── CTA ───── -->
<section style="position:relative;padding:8rem 0;overflow:hidden;" aria-labelledby="cta-h2">
  <img loading="lazy" decoding="async" src="/images/shared/photo-1526506118085-60ce8714f8c5-1920.webp"
    alt="Athlete at the top of a heavy deadlift under chalk dust" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" />
  <div style="position:absolute;inset:0;background:rgba(0,0,0,.8);"></div>
  <div style="position:absolute;inset:0;border-top:4px solid #dc2626;border-bottom:4px solid #dc2626;pointer-events:none;"></div>
  <div style="position:relative;z-index:10;text-align:center;max-width:56rem;margin:0 auto;padding:0 1.5rem;">
    <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:.75rem;letter-spacing:.5em;color:#dc2626;text-transform:uppercase;margin-bottom:1.5rem;">Zero Cost · Zero Commitment</p>
    <h2 id="cta-h2" style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:clamp(3rem,8vw,7rem);color:#fff;text-transform:uppercase;line-height:.92;margin-bottom:1.5rem;">FREE INTAKE<br/><span style="color:#dc2626;">SESSION.</span><br/>TODAY.</h2>
    <p style="font-family:'Barlow',sans-serif;color:#d1d5db;font-size:1.1rem;margin-bottom:2.5rem;">No pitch. No obligation. Just a frank conversation about your goals and whether we're the right fit.</p>
    <a href="#booking" style="display:inline-block;background:#dc2626;color:#fff;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.75rem;letter-spacing:.2em;text-transform:uppercase;text-decoration:none;padding:1.25rem 3.5rem;">BOOK NOW — IT'S FREE</a>
  </div>
</section>

<!-- ───── LOCATION ───── -->
<section id="location" style="background:#000;padding:5rem 0;" aria-labelledby="loc-h2">
  <div style="max-width:1280px;margin:0 auto;padding:0 1.5rem;display:grid;grid-template-columns:1fr 1fr;gap:4rem;">
    <div>
      <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:.75rem;letter-spacing:.4em;color:#dc2626;text-transform:uppercase;margin-bottom:.75rem;">Find Us</p>
      <h2 id="loc-h2" style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:3rem;color:#fff;text-transform:uppercase;margin-bottom:2rem;">LOCATION &amp; HOURS</h2>
      <address style="font-style:normal;color:#d4d4d8;margin-bottom:2rem;line-height:2;">
        <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.5rem;color:#fff;text-transform:uppercase;">{coach.gym}</p>
        <p style="font-family:'Barlow',sans-serif;">{coach.address.street}</p>
        <p style="font-family:'Barlow',sans-serif;">{coach.address.city}</p>
        <p style="margin-top:.75rem;"><a href={`tel:${coach.phone.replace(/\D/g,'')}`} style="color:#dc2626;text-decoration:none;font-family:'Barlow Condensed',sans-serif;font-weight:700;">{coach.phone}</a></p>
        <p><a href={`mailto:${coach.email}`} style="color:#dc2626;text-decoration:none;font-family:'Barlow Condensed',sans-serif;font-weight:700;">{coach.email}</a></p>
      </address>
      <table style="width:100%;border-collapse:collapse;" aria-label="Training hours">
        <tbody>
          {coach.hours.map(h => (
            <tr style="border-bottom:1px solid #27272a;">
              <td style="font-family:'Barlow',sans-serif;color:#e4e4e7;padding:.875rem 0;font-weight:600;">{h.day}</td>
              <td style="font-family:'Barlow Condensed',sans-serif;color:#dc2626;font-weight:700;font-size:1.1rem;text-align:right;padding:.875rem 0;">{h.hours}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <div style="position:relative;background:#09090b;display:flex;align-items:center;justify-content:center;min-height:20rem;overflow:hidden;">
      <img loading="lazy" decoding="async" src="/images/shared/photo-1540497077202-7c8a3999166f-1920.webp" alt="Steel Athletics training floor" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.35;" />
      <div style="position:relative;z-index:1;text-align:center;padding:2rem;">
        <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:2rem;color:#fff;text-transform:uppercase;">Elite Facility</p>
        <p style="font-family:'Barlow',sans-serif;color:#9ca3af;margin-top:.5rem;font-size:.875rem;">Platforms · Monolift · Full Calibrated Plate Set · Sleds · Competition Setup</p>
      </div>
    </div>
  </div>
</section>

<!-- ───── BOOKING ───── -->
<section id="booking" style="background:#09090b;padding:5rem 0;" aria-labelledby="book-h2">
  <div style="max-width:48rem;margin:0 auto;padding:0 1.5rem;">
    <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:.75rem;letter-spacing:.4em;color:#dc2626;text-transform:uppercase;margin-bottom:.75rem;">Let's Go</p>
    <h2 id="book-h2" style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:3.5rem;color:#fff;text-transform:uppercase;margin-bottom:.5rem;">BOOK YOUR FREE INTAKE</h2>
    <p style="font-family:'Barlow',sans-serif;color:#6b7280;margin-bottom:2.5rem;">We respond within 24 hours. No cookie-cutter consultations — just real talk about your goals.</p>
    <form style="display:flex;flex-direction:column;gap:1.25rem;" aria-label="Free intake booking form" novalidate>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;">
        <div>
          <label for="v1-name" style="display:block;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.7rem;letter-spacing:.2em;color:#9ca3af;text-transform:uppercase;margin-bottom:.5rem;">Full Name <span aria-label="required" style="color:#dc2626;">*</span></label>
          <input type="text" id="v1-name" name="name" required autocomplete="name" placeholder="John Steel"
            style="width:100%;background:#000;border:2px solid #27272a;color:#fff;padding:.875rem 1rem;font-family:'Barlow',sans-serif;outline:none;box-sizing:border-box;" />
        </div>
        <div>
          <label for="v1-email" style="display:block;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.7rem;letter-spacing:.2em;color:#9ca3af;text-transform:uppercase;margin-bottom:.5rem;">Email <span aria-label="required" style="color:#dc2626;">*</span></label>
          <input type="email" id="v1-email" name="email" required autocomplete="email" placeholder="you@example.com"
            style="width:100%;background:#000;border:2px solid #27272a;color:#fff;padding:.875rem 1rem;font-family:'Barlow',sans-serif;outline:none;box-sizing:border-box;" />
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;">
        <div>
          <label for="v1-phone" style="display:block;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.7rem;letter-spacing:.2em;color:#9ca3af;text-transform:uppercase;margin-bottom:.5rem;">Phone</label>
          <input type="tel" id="v1-phone" name="phone" autocomplete="tel" placeholder="(619) 555-0000"
            style="width:100%;background:#000;border:2px solid #27272a;color:#fff;padding:.875rem 1rem;font-family:'Barlow',sans-serif;outline:none;box-sizing:border-box;" />
        </div>
        <div>
          <label for="v1-goal" style="display:block;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.7rem;letter-spacing:.2em;color:#9ca3af;text-transform:uppercase;margin-bottom:.5rem;">Goal <span aria-label="required" style="color:#dc2626;">*</span></label>
          <select id="v1-goal" name="goal" required style="width:100%;background:#000;border:2px solid #27272a;color:#fff;padding:.875rem 1rem;font-family:'Barlow',sans-serif;outline:none;box-sizing:border-box;">
            <option value="">Select goal</option>
            <option value="powerlifting">Compete in Powerlifting</option>
            <option value="strength">Raw Strength</option>
            <option value="recomp">Body Recomposition</option>
            <option value="athletic">Athletic Performance</option>
          </select>
        </div>
      </div>
      <div>
        <label for="v1-squat" style="display:block;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.7rem;letter-spacing:.2em;color:#9ca3af;text-transform:uppercase;margin-bottom:.5rem;">Current Squat / Bench / Deadlift (or N/A)</label>
        <input type="text" id="v1-squat" name="lifts" placeholder="e.g. 315 / 225 / 405 lbs — or 'just starting'"
          style="width:100%;background:#000;border:2px solid #27272a;color:#fff;padding:.875rem 1rem;font-family:'Barlow',sans-serif;outline:none;box-sizing:border-box;" />
      </div>
      <div>
        <label for="v1-msg" style="display:block;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.7rem;letter-spacing:.2em;color:#9ca3af;text-transform:uppercase;margin-bottom:.5rem;">Tell Marcus About Your Goals</label>
        <textarea id="v1-msg" name="message" rows="4" placeholder="Where are you now, where do you want to be, and what's in the way?"
          style="width:100%;background:#000;border:2px solid #27272a;color:#fff;padding:.875rem 1rem;font-family:'Barlow',sans-serif;outline:none;resize:none;box-sizing:border-box;"></textarea>
      </div>
      <button type="submit" style="background:#dc2626;color:#fff;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.75rem;letter-spacing:.2em;text-transform:uppercase;border:none;padding:1.25rem;cursor:pointer;width:100%;">
        SUBMIT — LET'S GET TO WORK
      </button>
      <p style="text-align:center;font-family:'Barlow',sans-serif;font-size:.75rem;color:#52525b;">No commitment. No payment. Just a real conversation about your goals.</p>
    </form>
  </div>
</section>

</main>

<footer style="background:#000;border-top:2px solid #dc2626;padding:2.5rem 1.5rem;text-align:center;">
  <p style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.5rem;color:#fff;letter-spacing:.2em;text-transform:uppercase;">STEEL ATHLETICS</p>
  <p style="font-family:'Barlow',sans-serif;font-size:.75rem;color:#3f3f46;margin-top:.5rem;text-transform:uppercase;letter-spacing:.1em;">© {new Date().getFullYear()} Steel Athletics · San Diego, CA</p>
  <p style="margin-top:.5rem;"><a href="/" style="color:#3f3f46;font-family:'Barlow',sans-serif;font-size:.75rem;text-decoration:none;">← All Templates</a></p>
</footer>

<script is:inline>
function calcRM() {
  var w = parseFloat(document.getElementById('calc-weight').value);
  var r = parseInt(document.getElementById('calc-reps').value);
  if (!w || !r || w <= 0 || r < 1 || r > 15) {
    alert('Enter a valid weight (1–2000 lbs) and rep count (1–15).');
    return;
  }
  var rm = Math.round(w * (1 + r / 30));
  document.getElementById('rm-value').textContent = rm;
  var percs = [50,65,75,85,90,95,97,100];
  percs.forEach(function(p) {
    var el = document.getElementById('p' + p);
    if (el) el.textContent = Math.round(rm * p / 100) + ' lbs';
  });
  document.getElementById('rm-result').style.display = 'block';
  document.getElementById('rm-result').scrollIntoView({behavior:'smooth',block:'nearest'});
}
document.getElementById('calc-weight').addEventListener('keydown', function(e){ if(e.key==='Enter') calcRM(); });
document.getElementById('calc-reps').addEventListener('keydown', function(e){ if(e.key==='Enter') calcRM(); });
</script>

</BaseLayout>
