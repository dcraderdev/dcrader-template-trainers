---
import BaseLayout from '../layouts/BaseLayout.astro';
import { coach } from '../data/v1-coach';
---
<BaseLayout
  title={`${coach.name} | ${coach.gym} — Elite Strength Coaching`}
  description={coach.tagline}
  fontUrl="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@400;500;600&display=swap"
  themeColor="#000000"
  ogImage="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=1200&q=80"
>
  <!-- Nav -->
  <nav aria-label="Main navigation" class="fixed top-0 w-full z-50 bg-black/90 backdrop-blur-sm border-b border-red-900/30">
    <div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-16">
      <a href="#main-content" class="font-barlow text-2xl font-black tracking-widest text-white uppercase">{coach.gym}</a>
      <div class="hidden md:flex items-center gap-8">
        <a href="#programs" class="text-gray-400 hover:text-white text-xs uppercase tracking-widest transition-colors font-barlow font-semibold">Programs</a>
        <a href="#pricing" class="text-gray-400 hover:text-white text-xs uppercase tracking-widest transition-colors font-barlow font-semibold">Pricing</a>
        <a href="#coach" class="text-gray-400 hover:text-white text-xs uppercase tracking-widest transition-colors font-barlow font-semibold">Coach</a>
        <a href="#booking" class="bg-red-600 hover:bg-red-700 text-white px-5 py-2 text-xs uppercase tracking-widest font-barlow font-bold transition-colors">Book Free Session</a>
      </div>
      <a href="#booking" class="md:hidden bg-red-600 text-white px-4 py-2 text-xs uppercase tracking-widest font-barlow font-bold">Book</a>
    </div>
  </nav>

  <main id="main-content">
    <!-- Hero -->
    <section class="relative min-h-screen flex items-end pb-24 overflow-hidden" aria-labelledby="hero-heading">
      <img
        src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?auto=format&fit=crop&w=1920&q=80"
        alt="Heavy barbells and weight plates in a dark, dramatic gym"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-black via-black/75 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
      <div class="relative z-10 max-w-7xl mx-auto px-6 w-full">
        <p class="text-red-500 font-barlow text-sm font-bold uppercase tracking-[0.4em] mb-4">Elite Strength Coaching · San Diego, CA</p>
        <h1 id="hero-heading" class="font-barlow text-7xl sm:text-8xl md:text-[9rem] font-black text-white uppercase leading-none mb-6">
          FORGE<br/><span class="text-red-600">YOUR</span><br/>LEGEND
        </h1>
        <p class="text-gray-300 text-lg md:text-xl max-w-xl mb-10 font-barlow font-normal leading-relaxed">
          {coach.tagline}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-20">
          <a href="#booking" class="bg-red-600 hover:bg-red-700 text-white px-10 py-4 font-barlow font-black text-xl uppercase tracking-wider transition-all hover:scale-105 text-center">
            Claim Free Session
          </a>
          <a href="#programs" class="border border-white/30 hover:border-white text-white px-10 py-4 font-barlow font-bold text-xl uppercase tracking-wider transition-all text-center">
            View Programs
          </a>
        </div>
        <!-- Stats -->
        <div class="flex flex-wrap gap-10">
          {coach.achievements.map(a => (
            <div>
              <p class="font-barlow text-5xl font-black text-white leading-none">{a.value}</p>
              <p class="text-gray-400 text-xs uppercase tracking-widest mt-1 font-barlow">{a.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Transformations -->
    <section id="transformations" class="bg-zinc-950 py-24" aria-labelledby="trans-heading">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="text-red-500 font-barlow text-xs uppercase tracking-[0.4em] mb-3 font-bold">Real Results · Real People</p>
          <h2 id="trans-heading" class="font-barlow text-5xl md:text-6xl font-black text-white uppercase">Client Transformations</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {coach.transformations.map(t => (
            <article class="bg-zinc-900 overflow-hidden">
              <div class="grid grid-cols-2 relative">
                <div class="relative">
                  <img src={t.beforeImg} alt={`${t.name} before transformation`} class="w-full h-56 object-cover object-top" />
                  <span class="absolute top-2 left-2 bg-zinc-800/90 text-gray-300 text-xs font-barlow font-bold uppercase tracking-wider px-2 py-1">Before</span>
                </div>
                <div class="relative">
                  <img src={t.afterImg} alt={`${t.name} after transformation`} class="w-full h-56 object-cover object-top" />
                  <span class="absolute top-2 right-2 bg-red-600 text-white text-xs font-barlow font-bold uppercase tracking-wider px-2 py-1">After</span>
                </div>
                <div class="absolute inset-y-0 left-1/2 -translate-x-1/2 flex items-center pointer-events-none z-10">
                  <div class="w-8 h-8 bg-red-600 flex items-center justify-center text-white font-barlow font-black text-xs">VS</div>
                </div>
              </div>
              <div class="p-5">
                <p class="font-barlow text-xl font-black text-white uppercase">{t.name}</p>
                <p class="text-red-500 font-barlow font-bold text-sm mt-1">{t.result}</p>
                <p class="text-gray-400 text-sm mt-2 italic">"{t.quote}"</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Programs -->
    <section id="programs" class="bg-black py-24" aria-labelledby="programs-heading">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="text-red-500 font-barlow text-xs uppercase tracking-[0.4em] mb-3 font-bold">Training Systems</p>
          <h2 id="programs-heading" class="font-barlow text-5xl md:text-6xl font-black text-white uppercase">Programs Built to Dominate</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-px bg-zinc-800">
          {coach.programs.map(prog => (
            <div class="bg-zinc-950 p-8 hover:bg-zinc-900 transition-colors">
              <div class="text-4xl mb-5" aria-hidden="true">{prog.icon}</div>
              <h3 class="font-barlow text-3xl font-black text-white uppercase mb-3">{prog.name}</h3>
              <p class="text-gray-400 text-sm leading-relaxed mb-6">{prog.description}</p>
              <ul class="space-y-2">
                {prog.features.map(f => (
                  <li class="flex items-start gap-2 text-sm text-gray-300">
                    <span class="text-red-500 mt-0.5 font-bold" aria-hidden="true">▶</span>
                    {f}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section id="pricing" class="bg-zinc-950 py-24" aria-labelledby="pricing-heading">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="text-red-500 font-barlow text-xs uppercase tracking-[0.4em] mb-3 font-bold">Investment</p>
          <h2 id="pricing-heading" class="font-barlow text-5xl md:text-6xl font-black text-white uppercase">Choose Your Arsenal</h2>
          <p class="text-gray-400 mt-4 text-sm">All plans include a free intro session. No contracts.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {coach.pricing.map(tier => (
            <div class={`relative p-8 border ${tier.popular ? 'border-red-600 bg-red-950/20' : 'border-zinc-700 bg-zinc-900'}`}>
              {tier.popular && (
                <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-red-600 text-white text-xs font-barlow font-black uppercase tracking-wider px-4 py-1">Most Popular</span>
              )}
              <p class="font-barlow text-xl font-bold text-gray-400 uppercase tracking-widest">{tier.name}</p>
              <p class="font-barlow text-6xl font-black text-white mt-2 leading-none">
                ${tier.price}<span class="text-2xl text-gray-500 font-normal">/mo</span>
              </p>
              <ul class="my-8 space-y-3">
                {tier.features.map(f => (
                  <li class="flex items-start gap-3 text-gray-300 text-sm">
                    <span class="text-red-500 font-bold mt-0.5" aria-hidden="true">✓</span>
                    {f}
                  </li>
                ))}
              </ul>
              <a href="#booking" class={`block text-center py-3 font-barlow font-black text-lg uppercase tracking-wider transition-colors ${tier.popular ? 'bg-red-600 hover:bg-red-700 text-white' : 'border border-zinc-600 hover:border-white text-white'}`}>
                Get Started
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Coach Bio -->
    <section id="coach" class="bg-black py-24" aria-labelledby="coach-heading">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid md:grid-cols-2 gap-16 items-center">
          <div class="relative">
            <img
              src={coach.photo}
              alt={`${coach.name}, ${coach.title} at ${coach.gym}`}
              class="w-full aspect-[3/4] object-cover"
            />
            <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/90 to-transparent p-6">
              <div class="flex flex-wrap gap-2">
                {coach.certifications.map(cert => (
                  <span class="bg-red-600 text-white text-xs font-barlow font-bold uppercase tracking-wider px-3 py-1">{cert}</span>
                ))}
              </div>
            </div>
          </div>
          <div>
            <p class="text-red-500 font-barlow text-xs uppercase tracking-[0.4em] mb-3 font-bold">Your Coach</p>
            <h2 id="coach-heading" class="font-barlow text-6xl font-black text-white uppercase leading-tight">{coach.name}</h2>
            <p class="font-barlow text-2xl text-red-500 uppercase tracking-wider mt-1 mb-8 font-bold">{coach.title}</p>
            <p class="text-gray-200 text-lg leading-relaxed mb-4">{coach.bio}</p>
            <p class="text-gray-400 leading-relaxed mb-10">{coach.bioExtended}</p>
            <div class="grid grid-cols-2 gap-6">
              {coach.achievements.map(a => (
                <div class="border-l-2 border-red-600 pl-4">
                  <p class="font-barlow text-3xl font-black text-white">{a.value}</p>
                  <p class="text-gray-400 text-xs uppercase tracking-widest mt-1">{a.label}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section id="testimonials" class="bg-zinc-950 py-24" aria-labelledby="testimonials-heading">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="text-red-500 font-barlow text-xs uppercase tracking-[0.4em] mb-3 font-bold">The Proof</p>
          <h2 id="testimonials-heading" class="font-barlow text-5xl font-black text-white uppercase">Results Speak Louder</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {coach.testimonials.map(t => (
            <blockquote class="bg-zinc-900 p-8 border border-zinc-800">
              <div class="text-red-600 text-5xl font-serif leading-none mb-4" aria-hidden="true">"</div>
              <p class="text-gray-300 leading-relaxed mb-6 text-sm">{t.text}</p>
              <footer class="flex items-end justify-between">
                <div>
                  <cite class="not-italic font-barlow text-xl font-black text-white">{t.name}</cite>
                  <p class="text-gray-500 text-xs mt-0.5">{t.details}</p>
                </div>
                <p class="font-barlow text-3xl font-black text-red-500">{t.result}</p>
              </footer>
            </blockquote>
          ))}
        </div>
      </div>
    </section>

    <!-- Free Intro CTA -->
    <section class="relative py-32 overflow-hidden" aria-labelledby="cta-heading">
      <img
        src="https://images.unsplash.com/photo-1526506118085-60ce8714f8c5?auto=format&fit=crop&w=1920&q=80"
        alt="Athlete performing intense barbell lift in gym"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black/78"></div>
      <div class="relative z-10 text-center max-w-3xl mx-auto px-6">
        <p class="text-red-500 font-barlow text-xs uppercase tracking-[0.4em] mb-4 font-bold">Zero Risk</p>
        <h2 id="cta-heading" class="font-barlow text-6xl md:text-8xl font-black text-white uppercase leading-none mb-6">
          FREE INTRO<br/><span class="text-red-600">SESSION</span>
        </h2>
        <p class="text-gray-300 text-xl mb-10">Experience elite coaching firsthand. No commitment. No payment required.</p>
        <a href="#booking" class="inline-block bg-red-600 hover:bg-red-700 text-white px-14 py-5 font-barlow font-black text-2xl uppercase tracking-widest transition-all hover:scale-105">
          Claim My Free Session
        </a>
      </div>
    </section>

    <!-- Location & Hours -->
    <section id="location" class="bg-black py-24" aria-labelledby="location-heading">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid md:grid-cols-2 gap-16">
          <div>
            <p class="text-red-500 font-barlow text-xs uppercase tracking-[0.4em] mb-3 font-bold">Find Us</p>
            <h2 id="location-heading" class="font-barlow text-4xl font-black text-white uppercase mb-8">Location &amp; Hours</h2>
            <address class="not-italic text-gray-300 mb-8 text-sm leading-loose">
              <p class="font-barlow text-xl font-bold text-white uppercase">{coach.gym}</p>
              <p class="mt-2">{coach.address.street}</p>
              <p>{coach.address.city}</p>
              <p class="mt-3">
                <a href={`tel:${coach.phone.replace(/\D/g,'')}`} class="text-red-500 hover:text-red-400 transition-colors">{coach.phone}</a>
              </p>
              <p>
                <a href={`mailto:${coach.email}`} class="text-red-500 hover:text-red-400 transition-colors">{coach.email}</a>
              </p>
            </address>
            <h3 class="font-barlow text-xl font-bold text-white uppercase mb-4">Training Hours</h3>
            <table class="w-full text-sm" aria-label="Training hours">
              <tbody>
                {coach.hours.map(h => (
                  <tr class="border-b border-zinc-800">
                    <td class="py-3 text-gray-200 font-semibold">{h.day}</td>
                    <td class="py-3 text-right text-gray-400">{h.hours}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <div class="relative min-h-64 bg-zinc-900 overflow-hidden flex items-center justify-center">
            <img
              src="https://images.unsplash.com/photo-1540497077202-7c8a3999166f?auto=format&fit=crop&w=800&q=80"
              alt="Steel Athletics training facility interior with racks and platforms"
              class="absolute inset-0 w-full h-full object-cover opacity-30"
            />
            <div class="relative z-10 text-center p-10">
              <p class="font-barlow text-3xl font-black text-white uppercase mb-3">{coach.gym}</p>
              <p class="text-gray-300 text-sm">State-of-the-art equipment</p>
              <p class="text-gray-300 text-sm">Dedicated training platforms</p>
              <p class="text-gray-300 text-sm">Full powerlifting setup</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Booking Form -->
    <section id="booking" class="bg-zinc-950 py-24" aria-labelledby="booking-heading">
      <div class="max-w-3xl mx-auto px-6">
        <div class="text-center mb-12">
          <p class="text-red-500 font-barlow text-xs uppercase tracking-[0.4em] mb-3 font-bold">Get Started</p>
          <h2 id="booking-heading" class="font-barlow text-5xl font-black text-white uppercase">Book Your Free Session</h2>
          <p class="text-gray-400 mt-4 text-sm">Complete the form below and Marcus will be in touch within 24 hours.</p>
        </div>
        <form class="space-y-6" aria-label="Booking request form" novalidate>
          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <label for="v1-name" class="block text-gray-300 text-xs uppercase tracking-widest mb-2 font-barlow font-bold">Full Name <span aria-label="required">*</span></label>
              <input type="text" id="v1-name" name="name" required autocomplete="name" placeholder="John Steel"
                class="w-full bg-zinc-800 border border-zinc-700 text-white px-4 py-3 focus:border-red-500 focus:outline-none transition-colors placeholder:text-zinc-600 text-sm" />
            </div>
            <div>
              <label for="v1-email" class="block text-gray-300 text-xs uppercase tracking-widest mb-2 font-barlow font-bold">Email <span aria-label="required">*</span></label>
              <input type="email" id="v1-email" name="email" required autocomplete="email" placeholder="john@example.com"
                class="w-full bg-zinc-800 border border-zinc-700 text-white px-4 py-3 focus:border-red-500 focus:outline-none transition-colors placeholder:text-zinc-600 text-sm" />
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <label for="v1-phone" class="block text-gray-300 text-xs uppercase tracking-widest mb-2 font-barlow font-bold">Phone</label>
              <input type="tel" id="v1-phone" name="phone" autocomplete="tel" placeholder="(619) 555-0000"
                class="w-full bg-zinc-800 border border-zinc-700 text-white px-4 py-3 focus:border-red-500 focus:outline-none transition-colors placeholder:text-zinc-600 text-sm" />
            </div>
            <div>
              <label for="v1-goal" class="block text-gray-300 text-xs uppercase tracking-widest mb-2 font-barlow font-bold">Primary Goal <span aria-label="required">*</span></label>
              <select id="v1-goal" name="goal" required
                class="w-full bg-zinc-800 border border-zinc-700 text-white px-4 py-3 focus:border-red-500 focus:outline-none transition-colors text-sm">
                <option value="">Select your goal</option>
                <option value="strength">Build Strength &amp; Size</option>
                <option value="fat-loss">Lose Body Fat</option>
                <option value="performance">Athletic Performance</option>
                <option value="powerlifting">Compete in Powerlifting</option>
                <option value="general">General Fitness</option>
              </select>
            </div>
          </div>
          <div>
            <label for="v1-experience" class="block text-gray-300 text-xs uppercase tracking-widest mb-2 font-barlow font-bold">Training Experience</label>
            <select id="v1-experience" name="experience"
              class="w-full bg-zinc-800 border border-zinc-700 text-white px-4 py-3 focus:border-red-500 focus:outline-none transition-colors text-sm">
              <option value="beginner">Beginner (0–1 years)</option>
              <option value="intermediate">Intermediate (1–3 years)</option>
              <option value="advanced">Advanced (3+ years)</option>
              <option value="competitor">Competitive Athlete</option>
            </select>
          </div>
          <div>
            <label for="v1-message" class="block text-gray-300 text-xs uppercase tracking-widest mb-2 font-barlow font-bold">Tell Us About Your Goals</label>
            <textarea id="v1-message" name="message" rows="4" placeholder="Share your goals, current routine, and what's holding you back..."
              class="w-full bg-zinc-800 border border-zinc-700 text-white px-4 py-3 focus:border-red-500 focus:outline-none transition-colors placeholder:text-zinc-600 resize-none text-sm"></textarea>
          </div>
          <button type="submit" class="w-full bg-red-600 hover:bg-red-700 text-white py-5 font-barlow font-black text-2xl uppercase tracking-widest transition-all hover:scale-[1.02]">
            Claim My Free Session
          </button>
          <p class="text-center text-zinc-600 text-xs">No commitment. No payment required. We'll respond within 24 hours.</p>
        </form>
      </div>
    </section>
  </main>

  <footer class="bg-black border-t border-zinc-900 py-12">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <p class="font-barlow text-2xl font-black text-white uppercase tracking-widest">{coach.gym}</p>
      <p class="text-zinc-600 text-xs mt-3 uppercase tracking-widest">© {new Date().getFullYear()} {coach.gym}. All rights reserved.</p>
      <p class="text-zinc-700 text-xs mt-2">
        <a href="/" class="hover:text-zinc-400 transition-colors">← All Templates</a>
      </p>
    </div>
  </footer>
</BaseLayout>
