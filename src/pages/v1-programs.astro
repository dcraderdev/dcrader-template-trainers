---
import BaseLayout from '../layouts/BaseLayout.astro';
import { coach } from '../data/v1-coach';

// Block-by-block periodization breakdown — what an actual 16-week macrocycle looks like
const blocks = [
  {
    n: '01',
    name: 'Accumulation',
    weeks: 'Weeks 1–4',
    focus: 'Hypertrophy & Work Capacity',
    intensity: '60–72% 1RM',
    volume: '18–22 working sets per session',
    rep: '8–12 reps · 90–120s rest',
    why: 'Foundation. We push the muscle-building stimulus while letting the nervous system recover from the prior peak. This is where the squat and bench come back in volume after the meet — and where new athletes earn the right to load heavier later.',
  },
  {
    n: '02',
    name: 'Transmutation',
    weeks: 'Weeks 5–9',
    focus: 'Strength & Specificity',
    intensity: '75–87% 1RM',
    volume: '12–16 working sets per session',
    rep: '3–6 reps · 3–5 min rest',
    why: 'The volume cuts, the bar speed sharpens. We start pulling against bands and chains on the deadlift, the bench press gets paused work, and squat technique tightens up under heavier loads. Bar speed is tracked on every working set with a velocity sensor.',
  },
  {
    n: '03',
    name: 'Realization',
    weeks: 'Weeks 10–13',
    focus: 'Peak Strength',
    intensity: '88–95% 1RM',
    volume: '6–10 working sets per session',
    rep: '1–3 reps · 4–7 min rest',
    why: 'The intensity phase. Singles, doubles, and the occasional heavy triple. We program two heavy days and two skill days per week. Every rep is recorded on video and reviewed inside 24 hours so cues stay sharp.',
  },
  {
    n: '04',
    name: 'Deload + Test',
    weeks: 'Weeks 14–16',
    focus: 'Recovery & 1RM Test',
    intensity: '50–100% in waves',
    volume: 'Cut 40% the first 7 days, then build to test',
    rep: 'Test singles + meet attempts',
    why: 'Volume drops by half. Sleep and food go up. We do one heavy opener at 90% on week 15, then a true test or a sanctioned meet on week 16. Athletes who deload properly hit 5–8% PRs at the end of the block, every time.',
  },
];

// What a typical week looks like inside the "Realization" peak block
const week = [
  { day: 'MON', title: 'Heavy Squat', work: 'Comp squat singles 88-92%, pause squats 3x4, bulgarian split squat 3x8/leg, hamstring curls' },
  { day: 'TUE', title: 'Bench Press', work: 'Comp bench 4x3 @ 85-90%, close grip 3x5, weighted dips 3x6, lat work 3x12' },
  { day: 'WED', title: 'Active Recovery', work: 'Cardio Z2 30-40 min, mobility (hips + thoracic), prehab band work' },
  { day: 'THU', title: 'Heavy Deadlift', work: 'Comp deadlift singles 88-92%, deficit deadlift 3x4, RDL 3x6, ab wheel 4x10' },
  { day: 'FRI', title: 'Skill Bench + Acc', work: 'Speed bench 8x3 @ 60%, paused incline 3x5, rows 4x8, biceps + triceps work' },
  { day: 'SAT', title: 'Squat Variation', work: 'SSB squat or front squat 4x4, walking lunges 3x10/leg, GHR 4x8, planks' },
  { day: 'SUN', title: 'Rest', work: 'Sleep. Food. Walk. We mean it.' },
];

// Three program tracks
const tracks = [
  { tag: 'TRACK A', name: 'Compete', who: 'Sanctioned powerlifters chasing a meet PR within the next 16 weeks.', focus: 'Attempt selection, peaking, openers/seconds/thirds calculation, meet-day handler protocol included.' },
  { tag: 'TRACK B', name: 'Recompose', who: 'Lifters who want to add 20 lbs to the big three while losing fat.', focus: 'Conjugate-style training paired with macro periodization. Two strength days, two hypertrophy days, two conditioning sessions per week.' },
  { tag: 'TRACK C', name: 'Rebuild', who: 'Returning lifters or post-injury athletes needing pattern repair before load.', focus: 'Eight-week movement re-pattern with FMS scoring at intake, RPE-capped sets, and a velocity-based progression once the pattern is clean.' },
];
---

<BaseLayout
