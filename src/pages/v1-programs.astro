      <a href="/v1-strength-elite#booking" style="background:#dc2626;color:#fff;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:.75rem;letter-spacing:.2em;text-transform:uppercase;text-decoration:none;padding:.5rem 1.25rem;">BOOK FREE INTAKE</a>
    </div>
