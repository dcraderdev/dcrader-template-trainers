---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { coach } from '../../data/v2-coach';
---
<BaseLayout
  title="Accessibility Statement | Chen Performance Coaching"
  description="Accessibility statement and commitment for Chen Performance Coaching."
  fontUrl="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&display=swap"
  themeColor="#65a30d"
>
<nav aria-label="Main navigation" style="position:sticky;top:0;z-index:50;background:rgba(255,255,255,.97);backdrop-filter:blur(8px);border-bottom:1px solid #e5e7eb;font-family:'DM Sans',sans-serif;">
  <div style="max-width:1152px;margin:0 auto;padding:0 1.5rem;display:flex;align-items:center;justify-content:space-between;height:64px;">
    <a href="/v2-online-coach" style="font-weight:700;font-size:1.125rem;color:#111827;text-decoration:none;letter-spacing:-.025em;">Chen Performance <span style="color:#4d7c0f;">Coaching</span></a>
    <a href="/v2-online-coach" style="color:#6b7280;font-size:.875rem;text-decoration:none;font-weight:500;">← Back to home</a>
  </div>
</nav>
<main id="main-content" style="background:#fff;color:#111827;min-height:100vh;padding:5rem 1.5rem;font-family:'DM Sans',sans-serif;">
  <div style="max-width:42rem;margin:0 auto;line-height:1.7;">
    <span style="display:inline-block;background:#f0fdf4;color:#4d7c0f;font-size:.75rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase;padding:.375rem .875rem;border-radius:999px;margin-bottom:1rem;">Compliance</span>
    <h1 style="font-size:2.5rem;font-weight:700;color:#111827;letter-spacing:-.03em;margin-bottom:1.5rem;line-height:1.1;">Accessibility Statement</h1>
    <p style="color:#374151;margin-bottom:1.25rem;font-size:1.05rem;">Chen Performance Coaching is committed to ensuring digital accessibility for people of all abilities. We strive to conform to WCAG 2.1 Level AA standards and continuously improve the user experience for everyone.</p>
    <p style="color:#374151;margin-bottom:1.25rem;font-size:1.05rem;">If you experience any difficulty accessing this website, or need accommodations, please contact us at <a href={`mailto:${coach.email}`} style="color:#4d7c0f;text-decoration:underline;font-weight:600;">{coach.email}</a> or <a href={`tel:${coach.phone.replace(/\D/g,'')}`} style="color:#4d7c0f;text-decoration:underline;font-weight:600;">{coach.phone}</a> and we will work to provide the information or service through alternative communication.</p>
    <p style="color:#6b7280;font-size:.9375rem;border-top:1px solid #e5e7eb;padding-top:1.25rem;margin-top:2rem;">This site is reviewed regularly. Last updated: 2026-05-17.</p>
  </div>
</main>
<footer style="background:#111827;padding:3rem 1.5rem;text-align:center;font-family:'DM Sans',sans-serif;">
  <p style="color:#fff;font-weight:600;">{coach.gym}</p>
  <p style="margin-top:.5rem;"><a href="/v2-online-coach" style="color:#d1d5db;font-size:.75rem;text-decoration:none;">← Back to home</a></p>
</footer>
</BaseLayout>
