---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResponsiveImage from '../components/ResponsiveImage.astro';
import ProgramTiersHero from '../components/trainers/ProgramTiersHero.astro';
import { coach } from '../data/v5-coach.ts';
const HERO = '/images/shared/photo-1571019614242-c5c5dee9f50b';

const fontUrl =
  'https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap';

const schedule = [
  { time: '5:30 AM', mon: true,  tue: false, wed: true,  thu: false, fri: true,  sat: false, type: 'standard' },
  { time: '6:00 AM', mon: false, tue: true,  wed: false, thu: true,  fri: false, sat: false, type: 'standard' },
  { time: '6:30 AM', mon: true,  tue: false, wed: true,  thu: false, fri: true,  sat: false, type: 'standard' },
  { time: '7:00 AM', mon: false, tue: false, wed: false, thu: false, fri: false, sat: true,  type: 'community' },
  { time: '6:00 PM', mon: true,  tue: false, wed: true,  thu: false, fri: true,  sat: false, type: 'standard' },
  { time: '7:00 PM', mon: false, tue: true,  wed: false, thu: true,  fri: false, sat: false, type: 'standard' },
];
---

<BaseLayout
  title="Blaze Bootcamp | Miami Group Fitness | Tony Rivera"
  description="700+ members strong. Miami's hardest group bootcamp. Show up. Burn it down. Build each other up."
  fontUrl={fontUrl}
  themeColor="#FF5500"
  ogImage="/images/shared/photo-1571019614242-c5c5dee9f50b-1920.webp"
>
<Fragment slot="head">
  <link
    rel="preload"
    as="image"
    fetchpriority="high"
    type="image/avif"
    imagesrcset={`${HERO}-320.avif 320w, ${HERO}-640.avif 640w, ${HERO}-1024.avif 1024w, ${HERO}-1920.avif 1920w`}
    imagesizes="100vw"
  />
</Fragment>
  <style is:inline>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', sans-serif; background: #0A0A0A; color: #F5F5F5; }
    .oswald { font-family: 'Oswald', sans-serif; }
    .inter { font-family: 'Inter', sans-serif; }

    @keyframes borderPulse {
      0%, 100% { border-color: #FF5500; }
      50% { border-color: #FF8800; }
    }

    .tribe-badge {
      display: inline-flex; align-items: center; gap: 6px;
      background: #FF5500; color: #000; font-family: 'Oswald', sans-serif;
      font-weight: 700; font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase;
      padding: 4px 12px; border-radius: 2px;
    }

    .sched-cell {
      width: 48px; height: 48px; display: flex; align-items: center; justify-content: center;
      border-radius: 4px; transition: transform 0.15s;
    }
    .sched-cell:hover { transform: scale(1.1); }
    .sched-on { background: #FF5500; }
    .sched-community { background: #FFB300; }
    .sched-off { background: #1A1A1A; }

    .program-card { border: 1px solid #222; transition: border-color 0.2s, transform 0.2s; }
    .program-card:hover { border-color: #FF5500; transform: translateY(-4px); }

    .cta-btn {
      display: inline-block; background: #FF5500; color: #000; font-family: 'Oswald', sans-serif;
      font-weight: 700; font-size: 1.1rem; letter-spacing: 0.1em; text-transform: uppercase;
      padding: 18px 48px; text-decoration: none; border: none; cursor: pointer;
      transition: background 0.15s, transform 0.15s; clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 100%, 12px 100%);
    }
    .cta-btn:hover { background: #FF7700; transform: translateY(-2px); }

    .cta-btn-outline {
      display: inline-block; border: 2px solid #FF5500; color: #FF5500; font-family: 'Oswald', sans-serif;
      font-weight: 700; font-size: 1.1rem; letter-spacing: 0.1em; text-transform: uppercase;
      padding: 16px 46px; text-decoration: none; cursor: pointer;
      transition: background 0.15s, color 0.15s; clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 100%, 12px 100%);
    }
    .cta-btn-outline:hover { background: #FF5500; color: #000; }

    input, select, textarea {
      background: #111; border: 1px solid #333; color: #F5F5F5; font-family: 'Inter', sans-serif;
      font-size: 0.95rem; padding: 14px 16px; width: 100%; border-radius: 0;
      outline: none; transition: border-color 0.2s;
    }
    input:focus, select:focus, textarea:focus { border-color: #FF5500; }
    select option { background: #111; }

    @media (max-width: 768px) {
      .hero-grid { grid-template-columns: 1fr !important; }
      .programs-grid { grid-template-columns: 1fr !important; }
      .pricing-grid { grid-template-columns: 1fr !important; }
      .transform-grid { grid-template-columns: 1fr !important; }
      .tribe-grid { grid-template-columns: 1fr !important; }
      .coach-grid { grid-template-columns: 1fr !important; }
      .form-grid { grid-template-columns: 1fr !important; }
      .sched-table { font-size: 0.75rem; }
      .sched-cell { width: 36px; height: 36px; }
    }
  </style>

  <main id="main-content">

    <!-- NAV -->
    <nav aria-label="Main navigation" style="position:fixed;top:0;left:0;right:0;z-index:100;background:#000;border-bottom:3px solid #FF5500;">
      <div style="max-width:1200px;margin:0 auto;padding:0 24px;display:flex;align-items:center;justify-content:space-between;height:64px;">
        <a href="/v5-bootcamp-community" aria-label="Blaze Bootcamp home" style="text-decoration:none;display:flex;align-items:center;gap:12px;">
          <div style="width:36px;height:36px;background:#FF5500;display:flex;align-items:center;justify-content:center;font-family:'Oswald',sans-serif;font-weight:700;font-size:1.1rem;color:#000;clip-path:polygon(0 0,calc(100% - 6px) 0,100% 100%,6px 100%);">B</div>
          <span class="oswald" style="font-size:1.25rem;font-weight:700;letter-spacing:0.08em;color:#fff;text-transform:uppercase;">Blaze Bootcamp</span>
        </a>
        <div style="display:flex;align-items:center;gap:32px;">
          <a href="#schedule" class="oswald" style="color:#999;text-decoration:none;font-size:0.85rem;letter-spacing:0.1em;text-transform:uppercase;transition:color 0.15s;" onmouseover="this.style.color='#FF5500'" onmouseout="this.style.color='#999'">Schedule</a>
          <a href="#programs" class="oswald" style="color:#999;text-decoration:none;font-size:0.85rem;letter-spacing:0.1em;text-transform:uppercase;transition:color 0.15s;" onmouseover="this.style.color='#FF5500'" onmouseout="this.style.color='#999'">Programs</a>
          <a href="/v5-first-class" class="oswald" style="color:#999;text-decoration:none;font-size:0.85rem;letter-spacing:0.1em;text-transform:uppercase;transition:color 0.15s;" onmouseover="this.style.color='#FF5500'" onmouseout="this.style.color='#999'">First Class</a>
          <a href="#tribe" class="oswald" style="color:#999;text-decoration:none;font-size:0.85rem;letter-spacing:0.1em;text-transform:uppercase;transition:color 0.15s;" onmouseover="this.style.color='#FF5500'" onmouseout="this.style.color='#999'">The Tribe</a>
          <a href="#join" class="cta-btn" style="font-size:0.85rem;padding:10px 28px;">Join Free</a>
        </div>
      </div>
    </nav>

    <!-- HERO (Program Tiers component) -->
    <ProgramTiersHero coach={coach} />

    <!-- SUPPORTING: Next Session strip — was hero card, now a thin urgency rail -->
    <section style="background:#0A0A0A;padding:32px 24px;border-top:1px solid #1f1f1f;border-bottom:1px solid #1f1f1f;" aria-label="Next bootcamp session">
      <div style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:auto 1fr auto;gap:1.5rem;align-items:center;">
        <div style="display:flex;flex-direction:column;border-right:1px solid #222;padding-right:1.5rem;">
          <span class="oswald" style="font-size:0.7rem;letter-spacing:0.25em;text-transform:uppercase;color:#FF5500;">Next Session</span>
          <span class="oswald" style="font-size:1.8rem;font-weight:700;color:#fff;line-height:1.1;">6:30 AM · Monday</span>
          <span class="inter" style="font-size:0.78rem;color:#999;margin-top:.15rem;">Full Blaze WOD · {coach.address.street}</span>
        </div>
        <div style="display:flex;align-items:center;gap:.6rem;">
          <div style="display:flex;">
            {[1,2,3,4].map(() => (
              <div style="width:32px;height:32px;border-radius:50%;border:2px solid #0A0A0A;overflow:hidden;margin-left:-10px;">
                <div style="width:100%;height:100%;background:linear-gradient(135deg,#FF5500,#FFB300);"></div>
              </div>
            ))}
          </div>
          <span class="inter" style="font-size:0.82rem;color:#bbb;">12 signed up · <span style="color:#FF5500;font-weight:600;">8 spots left</span></span>
        </div>
        <a href="#join" class="cta-btn" style="font-size:.95rem;padding:14px 32px;">Reserve My Spot</a>
      </div>
    </section>

    <!-- TRUST BAR — coach credentials + "what we are/aren't" stance -->
    <section style="background:#FF5500;padding:14px 24px;">
      <div style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:auto 1fr;gap:1.5rem;align-items:center;">
        <span class="oswald" style="font-size:.7rem;font-weight:700;letter-spacing:.2em;color:#000;text-transform:uppercase;border-right:2px solid rgba(0,0,0,.25);padding-right:1.5rem;white-space:nowrap;">Coach Tony &middot; certified by</span>
        <div style="display:flex;flex-wrap:wrap;gap:1rem 1.5rem;align-items:center;">
          {coach.certifications.map((c) => (
            <span class="oswald" style="font-size:0.8rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#000;">{c}</span>
          ))}
          <span aria-hidden="true" style="color:rgba(0,0,0,.3);">|</span>
          <span class="oswald" style="font-size:0.78rem;font-weight:600;letter-spacing:.1em;color:#000;text-transform:uppercase;">Outdoor · All weather · No locker rooms · No mirrors</span>
        </div>
      </div>
    </section>

    <!-- CLASS SCHEDULE -->
    <section id="schedule" style="background:#0A0A0A;padding:96px 24px;">
      <div style="max-width:1100px;margin:0 auto;">
        <div style="text-align:center;margin-bottom:16px;">
          <span class="tribe-badge">Weekly Schedule</span>
        </div>
        <h2 class="oswald" style="text-align:center;font-size:clamp(2.2rem,5vw,3.5rem);font-weight:700;text-transform:uppercase;color:#fff;margin-bottom:8px;">
          When We <span style="color:#FF5500;">Train</span>
        </h2>
        <p class="inter" style="text-align:center;color:#999;max-width:500px;margin:0 auto 56px;">
          {coach.stats.classes} sessions per week. Bayfront Park, Miami. Rain or shine.
        </p>

        <div style="display:flex;gap:24px;justify-content:center;margin-bottom:32px;flex-wrap:wrap;">
          <div style="display:flex;align-items:center;gap:8px;">
            <div style="width:24px;height:24px;border-radius:3px;background:#FF5500;"></div>
            <span class="inter" style="font-size:0.85rem;color:#999;">Blaze WOD</span>
          </div>
          <div style="display:flex;align-items:center;gap:8px;">
            <div style="width:24px;height:24px;border-radius:3px;background:#FFB300;"></div>
            <span class="inter" style="font-size:0.85rem;color:#999;">Community WOD</span>
          </div>
          <div style="display:flex;align-items:center;gap:8px;">
            <div style="width:24px;height:24px;border-radius:3px;background:#1A1A1A;"></div>
            <span class="inter" style="font-size:0.85rem;color:#999;">No Session</span>
          </div>
        </div>

        <div style="overflow-x:auto;">
          <table class="sched-table" style="width:100%;border-collapse:separate;border-spacing:6px;" aria-label="Weekly class schedule">
            <thead>
              <tr>
                <th class="oswald" style="font-size:0.75rem;letter-spacing:0.12em;color:#999;text-transform:uppercase;text-align:left;padding:8px 12px;min-width:80px;" scope="col">Time</th>
                {['MON', 'TUE', 'WED', 'THU', 'FRI', 'SAT'].map((d) => (
                  <th class="oswald" style="font-size:0.8rem;letter-spacing:0.12em;color:#999;text-transform:uppercase;text-align:center;padding:8px 0;width:48px;" scope="col">{d}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {schedule.map((row) => (
                <tr>
                  <th class="oswald" style="font-size:0.95rem;font-weight:600;color:#CCC;padding:4px 12px;white-space:nowrap;text-align:left;" scope="row">{row.time}</th>
                  <td style="padding:4px;">
                    <div class={`sched-cell ${row.mon ? 'sched-on' : 'sched-off'}`}
                      aria-label={`Monday ${row.time}: ${row.mon ? 'Blaze WOD' : 'No session'}`}>
                      {row.mon && <span style="font-size:1rem;" aria-hidden="true">🔥</span>}
                    </div>
                  </td>
                  <td style="padding:4px;">
                    <div class={`sched-cell ${row.tue ? 'sched-on' : 'sched-off'}`}
                      aria-label={`Tuesday ${row.time}: ${row.tue ? 'Blaze WOD' : 'No session'}`}>
                      {row.tue && <span style="font-size:1rem;" aria-hidden="true">🔥</span>}
                    </div>
                  </td>
                  <td style="padding:4px;">
                    <div class={`sched-cell ${row.wed ? 'sched-on' : 'sched-off'}`}
                      aria-label={`Wednesday ${row.time}: ${row.wed ? 'Blaze WOD' : 'No session'}`}>
                      {row.wed && <span style="font-size:1rem;" aria-hidden="true">🔥</span>}
                    </div>
                  </td>
                  <td style="padding:4px;">
                    <div class={`sched-cell ${row.thu ? 'sched-on' : 'sched-off'}`}
                      aria-label={`Thursday ${row.time}: ${row.thu ? 'Blaze WOD' : 'No session'}`}>
                      {row.thu && <span style="font-size:1rem;" aria-hidden="true">🔥</span>}
                    </div>
                  </td>
                  <td style="padding:4px;">
                    <div class={`sched-cell ${row.fri ? 'sched-on' : 'sched-off'}`}
                      aria-label={`Friday ${row.time}: ${row.fri ? 'Blaze WOD' : 'No session'}`}>
                      {row.fri && <span style="font-size:1rem;" aria-hidden="true">🔥</span>}
                    </div>
                  </td>
                  <td style="padding:4px;">
                    <div class={`sched-cell ${row.sat ? 'sched-community' : 'sched-off'}`}
                      aria-label={`Saturday ${row.time}: ${row.sat ? 'Community WOD' : 'No session'}`}>
                      {row.sat && <span style="font-size:1rem;" aria-hidden="true">&#x2605;</span>}
                    </div>
                  </td>
                </tr>
              ))}
              <tr>
                <th class="oswald" style="font-size:0.95rem;font-weight:600;color:#999;padding:4px 12px;text-align:left;" scope="row">SUN</th>
                {[1,2,3,4,5,6].map(() => (
                  <td style="padding:4px;">
                    <div class="sched-cell sched-off" aria-label="Rest day">
                      <span style="font-size:0.65rem;color:#999;">REST</span>
                    </div>
                  </td>
                ))}
              </tr>
            </tbody>
          </table>
        </div>

        <div style="text-align:center;margin-top:48px;">
          <a href="#join" class="cta-btn">Book Your First Free Class</a>
          <p class="inter" style="font-size:0.8rem;color:#999;margin-top:16px;">No equipment needed · All fitness levels welcome · Show up and we handle the rest</p>
        </div>
      </div>
    </section>

    <!-- PROGRAMS -->
    <section id="programs" style="background:#111;padding:96px 24px;">
      <div style="max-width:1100px;margin:0 auto;">
        <div style="text-align:center;margin-bottom:16px;">
          <span class="tribe-badge">Training Programs</span>
        </div>
        <h2 class="oswald" style="text-align:center;font-size:clamp(2.2rem,5vw,3.5rem);font-weight:700;text-transform:uppercase;color:#fff;margin-bottom:56px;">
          Pick Your <span style="color:#FF5500;">Level</span>
        </h2>

        <div class="programs-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:2px;background:#FF5500;">
          {coach.programs.map((p) => (
            <div class="program-card" style="background:#0A0A0A;padding:40px 32px;border:none;">
              <div style="font-size:2.5rem;margin-bottom:20px;" aria-hidden="true">{p.icon}</div>
              <h3 class="oswald" style="font-size:1.6rem;font-weight:700;text-transform:uppercase;color:#fff;margin-bottom:12px;">{p.name}</h3>
              <p class="inter" style="font-size:0.9rem;color:#888;line-height:1.6;margin-bottom:28px;">{p.description}</p>
              <ul style="list-style:none;display:flex;flex-direction:column;gap:10px;" aria-label={`${p.name} features`}>
                {p.features.map((f) => (
                  <li class="inter" style="display:flex;align-items:flex-start;gap:10px;font-size:0.85rem;color:#CCC;">
                    <span style="color:#FF5500;font-size:1rem;line-height:1.2;flex-shrink:0;" aria-hidden="true">&#x25B8;</span>
                    {f}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- BLAZE FAMILY COMMUNITY -->
    <section id="tribe" style="background:#0A0A0A;padding:96px 24px;overflow:hidden;">
      <div style="max-width:1100px;margin:0 auto;">
        <div style="text-align:center;margin-bottom:16px;">
          <span class="tribe-badge">The Community</span>
        </div>
        <h2 class="oswald" style="text-align:center;font-size:clamp(2.2rem,5vw,3.5rem);font-weight:700;text-transform:uppercase;color:#fff;margin-bottom:16px;">
          The <span style="color:#FF5500;">Blaze Family</span>
        </h2>
        <p class="inter" style="text-align:center;color:#777;max-width:560px;margin:0 auto 64px;line-height:1.7;">
          700+ athletes. One mission. The Blaze Family isn't a tagline — it's the reason 95% of members never leave.
        </p>

        <!-- Photo mosaic -->
        <div style="display:grid;grid-template-columns:2fr 1fr 1fr;grid-template-rows:240px 200px;gap:4px;margin-bottom:72px;">
          <div style="grid-row:span 2;position:relative;overflow:hidden;">
            <img loading="lazy" decoding="async" src="/images/shared/photo-1571019614242-c5c5dee9f50b-1920.webp" alt="Blaze Bootcamp group training at Bayfront Park" style="width:100%;height:100%;object-fit:cover;" />
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.7) 0%,transparent 60%);"></div>
            <div style="position:absolute;bottom:20px;left:20px;">
              <div class="oswald" style="font-size:0.7rem;letter-spacing:0.15em;text-transform:uppercase;color:#FF5500;margin-bottom:4px;">Saturday Community WOD</div>
              <div class="oswald" style="font-size:1.3rem;font-weight:700;color:#fff;">Nobody Left Behind</div>
            </div>
          </div>
          <div style="overflow:hidden;">
            <img loading="lazy" decoding="async" src="/images/shared/photo-1517963879433-6ad2b056d712-1920.webp" alt="Members celebrating after completing a workout" style="width:100%;height:100%;object-fit:cover;" />
          </div>
          <div style="overflow:hidden;">
            <img loading="lazy" decoding="async" src="/images/shared/photo-1549476464-37392f717541-1920.webp" alt="Outdoor bootcamp session at sunrise" style="width:100%;height:100%;object-fit:cover;" />
          </div>
          <div style="overflow:hidden;">
            <img loading="lazy" decoding="async" src="/images/shared/photo-1518611012118-696072aa579a-1920.webp" alt="Members supporting each other during training" style="width:100%;height:100%;object-fit:cover;" />
          </div>
          <div style="overflow:hidden;background:#FF5500;display:flex;align-items:center;justify-content:center;padding:24px;">
            <div style="text-align:center;">
              <div class="oswald" style="font-size:3.5rem;font-weight:700;color:#000;line-height:1;">95%</div>
              <div class="oswald" style="font-size:0.8rem;letter-spacing:0.15em;text-transform:uppercase;color:#000;margin-top:4px;">Renewal Rate</div>
            </div>
          </div>
        </div>

        <!-- Community pillars -->
        <div class="tribe-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:#222;">
          {[
            { icon: '📲', title: 'WhatsApp Tribe', body: 'Daily check-ins, motivation drops, and accountability from 700 members who actually care if you show up.' },
            { icon: '🏅', title: 'Monthly Challenges', body: 'Leaderboards, PRs, and prizes. Friendly competition that pushes your limits without breaking bonds.' },
            { icon: '🎉', title: 'Community Events', body: 'Beach WODs, group obstacle races, member cookouts, and the annual Blaze Anniversary throwdown.' },
          ].map((p) => (
            <div style="background:#0F0F0F;padding:40px 32px;border-left:3px solid #FF5500;">
              <div style="font-size:2.2rem;margin-bottom:16px;" aria-hidden="true">{p.icon}</div>
              <h3 class="oswald" style="font-size:1.25rem;font-weight:700;text-transform:uppercase;color:#fff;margin-bottom:12px;">{p.title}</h3>
              <p class="inter" style="font-size:0.875rem;color:#777;line-height:1.65;">{p.body}</p>
            </div>
          ))}
        </div>

        <!-- Testimonials — "Member Roll Call" stacked banner rows -->
        <div style="margin-top:72px;">
          <div style="display:flex;align-items:center;gap:1rem;margin-bottom:24px;">
            <span aria-hidden="true" style="flex:1;height:1px;background:#222;"></span>
            <span class="oswald" style="font-size:.75rem;font-weight:700;letter-spacing:.2em;color:#FF5500;text-transform:uppercase;">Member Roll Call</span>
            <span aria-hidden="true" style="flex:1;height:1px;background:#222;"></span>
          </div>
          <div style="display:flex;flex-direction:column;gap:2px;background:#1a1a1a;">
            {coach.testimonials.map((t, i) => (
              <div style={`background:#0F0F0F;padding:28px 32px;display:grid;grid-template-columns:auto 1fr auto;gap:32px;align-items:center;border-left:4px solid ${i===1?'#FFB300':'#FF5500'};`}>
                <div style="display:flex;align-items:center;gap:16px;min-width:0;">
                  <div aria-hidden="true" style={`width:56px;height:56px;background:linear-gradient(135deg,${i===0?'#FF5500,#FFB300':i===1?'#FFB300,#FF5500':'#FF5500,#FF7700'});display:flex;align-items:center;justify-content:center;font-family:'Oswald',sans-serif;font-weight:700;font-size:1.5rem;color:#000;clip-path:polygon(0 0,calc(100% - 8px) 0,100% 100%,8px 100%);flex-shrink:0;`}>{t.name.charAt(0)}</div>
                  <div>
                    <div class="oswald" style="font-size:1rem;font-weight:700;color:#fff;text-transform:uppercase;letter-spacing:.05em;">{t.name}</div>
                    <div class="inter" style="font-size:0.75rem;color:#999;margin-top:2px;">{t.details}</div>
                  </div>
                </div>
                <p class="inter" style="font-size:0.875rem;color:#BBB;line-height:1.65;margin:0;font-style:italic;">"{t.text}"</p>
                <div class="oswald" style="font-size:1.4rem;font-weight:700;color:#FF5500;text-transform:uppercase;letter-spacing:.05em;white-space:nowrap;">{t.result}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- TRANSFORMATIONS -->
    <section style="background:#111;padding:96px 24px;">
      <div style="max-width:1100px;margin:0 auto;">
        <div style="text-align:center;margin-bottom:16px;">
          <span class="tribe-badge">Results</span>
        </div>
        <h2 class="oswald" style="text-align:center;font-size:clamp(2.2rem,5vw,3.5rem);font-weight:700;text-transform:uppercase;color:#fff;margin-bottom:56px;">
          Real Members. <span style="color:#FF5500;">Real Results.</span>
        </h2>

        <div class="transform-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;">
          {coach.transformations.map((t) => (
            <div style="overflow:hidden;">
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:3px;background:#FF5500;">
                <div style="overflow:hidden;aspect-ratio:3/4;">
                  <img loading="lazy" decoding="async" src={t.beforeImg} alt={`${t.name} before transformation`} style="width:100%;height:100%;object-fit:cover;filter:grayscale(80%);" />
                </div>
                <div style="overflow:hidden;aspect-ratio:3/4;">
                  <img loading="lazy" decoding="async" src={t.afterImg} alt={`${t.name} after transformation`} style="width:100%;height:100%;object-fit:cover;" />
                </div>
              </div>
              <div style="background:#0A0A0A;padding:20px;border-bottom:2px solid #FF5500;">
                <div class="oswald" style="font-size:1.1rem;font-weight:700;color:#FF5500;text-transform:uppercase;">{t.result}</div>
                <div class="oswald" style="font-size:0.9rem;color:#999;margin-bottom:8px;text-transform:uppercase;">{t.name}</div>
                <p class="inter" style="font-size:0.8rem;color:#888;font-style:italic;">"{t.quote}"</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- PRICING -->
    <section style="background:#0A0A0A;padding:96px 24px;">
      <div style="max-width:1100px;margin:0 auto;">
        <div style="text-align:center;margin-bottom:16px;">
          <span class="tribe-badge">Membership</span>
        </div>
        <h2 class="oswald" style="text-align:center;font-size:clamp(2.2rem,5vw,3.5rem);font-weight:700;text-transform:uppercase;color:#fff;margin-bottom:56px;">
          Join the <span style="color:#FF5500;">Tribe</span>
        </h2>

        <div class="pricing-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:2px;background:#FF5500;">
          {coach.pricing.map((p) => (
            <div style={`background:${p.popular ? '#151515' : '#0D0D0D'};padding:40px 32px;position:relative;`}>
              {p.popular && (
                <div class="oswald" style="position:absolute;top:-2px;left:50%;transform:translateX(-50%);background:#FF5500;color:#000;font-size:0.7rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;padding:4px 16px;white-space:nowrap;">Most Popular</div>
              )}
              <h3 class="oswald" style="font-size:1.4rem;font-weight:700;text-transform:uppercase;color:#fff;margin-bottom:8px;">{p.name}</h3>
              <div style="display:flex;align-items:baseline;gap:4px;margin-bottom:28px;">
                <span class="oswald" style="font-size:3rem;font-weight:700;color:#FF5500;line-height:1;">${p.price}</span>
                <span class="inter" style="font-size:0.85rem;color:#999;">/month</span>
              </div>
              <ul style="list-style:none;display:flex;flex-direction:column;gap:12px;margin-bottom:36px;" aria-label={`${p.name} plan features`}>
                {p.features.map((f) => (
                  <li class="inter" style="display:flex;align-items:center;gap:10px;font-size:0.875rem;color:#AAA;">
                    <span style="color:#FF5500;font-weight:700;" aria-hidden="true">&#x2713;</span>
                    {f}
                  </li>
                ))}
              </ul>
              <a href="#join" style={`display:block;text-align:center;padding:14px;font-family:'Oswald',sans-serif;font-weight:700;font-size:0.95rem;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;transition:all 0.15s;${p.popular ? 'background:#FF5500;color:#000;' : 'background:transparent;border:1px solid #333;color:#777;'}`}>
                {p.popular ? 'Get Started' : 'Choose Plan'}
              </a>
            </div>
          ))}
        </div>

        <p class="inter" style="text-align:center;font-size:0.8rem;color:#999;margin-top:24px;">
          All memberships include first class free. No contracts. Cancel anytime.
        </p>
      </div>
    </section>

    <!-- COACH BIO -->
    <section style="background:#111;padding:96px 24px;">
      <div style="max-width:1100px;margin:0 auto;">
        <div class="coach-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;">
          <div style="position:relative;">
            <div style="position:absolute;top:-16px;left:-16px;right:16px;bottom:16px;border:2px solid #FF5500;z-index:0;"></div>
            <img loading="lazy" decoding="async"
              src={coach.photo}
              alt={`${coach.name}, ${coach.title} at Blaze Bootcamp Miami`}
              style="width:100%;aspect-ratio:3/4;object-fit:cover;position:relative;z-index:1;"
            />
            <div style="position:absolute;bottom:0;left:0;right:0;z-index:2;background:linear-gradient(to top,rgba(0,0,0,0.9) 0%,transparent 100%);padding:32px;">
              <div class="oswald" style="font-size:1.6rem;font-weight:700;color:#fff;text-transform:uppercase;">{coach.name}</div>
              <div class="oswald" style="font-size:0.9rem;color:#FF5500;text-transform:uppercase;letter-spacing:0.1em;">{coach.title}</div>
            </div>
          </div>

          <div>
            <span class="tribe-badge" style="margin-bottom:24px;display:inline-block;">The Coach</span>
            <h2 class="oswald" style="font-size:clamp(2rem,4vw,3rem);font-weight:700;text-transform:uppercase;color:#fff;line-height:1.1;margin-bottom:24px;">
              Built From <span style="color:#FF5500;">Concrete Up.</span>
            </h2>
            <p class="inter" style="color:#AAA;line-height:1.75;margin-bottom:16px;">{coach.bio}</p>
            <p class="inter" style="color:#777;line-height:1.75;margin-bottom:36px;">{coach.bioExtended}</p>

            <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:36px;">
              {coach.certifications.map((c) => (
                <span class="oswald" style="font-size:0.75rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:6px 14px;border:1px solid #333;color:#999;">{c}</span>
              ))}
            </div>

            <!-- "On the floor today" — high-energy current-moment vignette, not a stats grid -->
            <div style="background:#0a0a0a;border:1px solid #2a2a2a;padding:18px 20px;">
              <div style="display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid #2a2a2a;padding-bottom:10px;margin-bottom:14px;">
                <div style="display:flex;align-items:center;gap:10px;">
                  <span aria-hidden="true" style="width:8px;height:8px;border-radius:50%;background:#FF5500;display:inline-block;box-shadow:0 0 8px #FF5500;"></span>
                  <span class="oswald" style="font-size:.75rem;font-weight:700;letter-spacing:.18em;color:#FF5500;text-transform:uppercase;">On the floor today</span>
                </div>
                <span class="inter" style="font-size:.7rem;color:#999;letter-spacing:.05em;">Tuesday · 6:00 PM session</span>
              </div>
              <p class="oswald" style="font-size:1.1rem;font-weight:700;color:#fff;text-transform:uppercase;letter-spacing:.04em;margin:0 0 6px;line-height:1.2;">Today's WOD — "BAYFRONT BURNER"</p>
              <p class="inter" style="font-size:.85rem;color:#bbb;margin:0 0 14px;line-height:1.5;">21-15-9 — KB swings · burpee box jumps · wall balls. Cap is 14 minutes. Tony's leading from the front.</p>
              <ul style="list-style:none;padding:0;margin:0;display:grid;grid-template-columns:1fr 1fr;gap:8px 14px;">
                <li class="inter" style="font-size:.78rem;color:#888;"><span style="color:#FF5500;font-weight:700;">42</span> &nbsp;athletes signed in</li>
                <li class="inter" style="font-size:.78rem;color:#888;"><span style="color:#FF5500;font-weight:700;">3</span> &nbsp;first-timers tonight</li>
                <li class="inter" style="font-size:.78rem;color:#888;"><span style="color:#FF5500;font-weight:700;">11</span> &nbsp;PR attempts on the board</li>
                <li class="inter" style="font-size:.78rem;color:#888;"><span style="color:#FF5500;font-weight:700;">82°F</span> &nbsp;feels like 88. Bring water.</li>
              </ul>
              <p class="inter" style="font-size:.7rem;color:#999;font-style:italic;margin:14px 0 0;border-top:1px solid #1a1a1a;padding-top:10px;">Walk-ins welcome — grab any open spot on the rig.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA BANNER -->
    <section style="position:relative;overflow:hidden;">
      <img loading="lazy" decoding="async"
        src="/images/shared/photo-1526506118085-60ce8714f8c5-1920.webp"
        alt="Blaze Bootcamp members after a hard workout"
        style="width:100%;height:400px;object-fit:cover;object-position:center top;display:block;"
      />
      <div style="position:absolute;inset:0;background:rgba(0,0,0,0.82);display:flex;align-items:center;justify-content:center;">
        <div style="text-align:center;padding:24px;">
          <h2 class="oswald" style="font-size:clamp(2.5rem,6vw,5rem);font-weight:700;text-transform:uppercase;color:#fff;line-height:0.95;margin-bottom:24px;">
            YOUR FIRST CLASS.<br/><span style="color:#FF5500;">ON US.</span>
          </h2>
          <p class="inter" style="color:#CCC;margin-bottom:36px;font-size:1.05rem;">No excuses. No experience required. Just show up.</p>
          <a href="#join" class="cta-btn" style="font-size:1.2rem;padding:20px 56px;">Reserve My Free Class</a>
        </div>
      </div>
    </section>

    <!-- LOCATION -->
    <section style="background:#0A0A0A;padding:80px 24px;">
      <div style="max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start;" class="coach-grid">
        <div>
          <h2 class="oswald" style="font-size:2rem;font-weight:700;text-transform:uppercase;color:#fff;margin-bottom:32px;">Find <span style="color:#FF5500;">Us</span></h2>
          <div style="display:flex;gap:16px;margin-bottom:24px;">
            <div style="width:40px;height:40px;background:#FF5500;display:flex;align-items:center;justify-content:center;flex-shrink:0;" aria-hidden="true">
              <span style="font-size:1.1rem;">&#x1F4CD;</span>
            </div>
            <div>
              <div class="oswald" style="color:#fff;font-size:1rem;text-transform:uppercase;">{coach.address.street}</div>
              <div class="inter" style="color:#999;font-size:0.875rem;">{coach.address.city}</div>
            </div>
          </div>
          <div style="display:flex;gap:16px;margin-bottom:24px;">
            <div style="width:40px;height:40px;background:#FF5500;display:flex;align-items:center;justify-content:center;flex-shrink:0;" aria-hidden="true">
              <span style="font-size:1.1rem;">&#x1F4DE;</span>
            </div>
            <div>
              <div class="oswald" style="color:#fff;font-size:1rem;text-transform:uppercase;">{coach.phone}</div>
              <div class="inter" style="color:#999;font-size:0.875rem;">Call or text anytime</div>
            </div>
          </div>
          <div style="display:flex;gap:16px;">
            <div style="width:40px;height:40px;background:#FF5500;display:flex;align-items:center;justify-content:center;flex-shrink:0;" aria-hidden="true">
              <span style="font-size:1.1rem;">&#x2709;&#xFE0F;</span>
            </div>
            <div>
              <div class="oswald" style="color:#fff;font-size:1rem;text-transform:uppercase;">{coach.email}</div>
              <div class="inter" style="color:#999;font-size:0.875rem;">Response within 2 hours</div>
            </div>
          </div>
        </div>

        <div>
          <h3 class="oswald" style="font-size:1.1rem;font-weight:700;text-transform:uppercase;color:#fff;margin-bottom:16px;letter-spacing:0.1em;">Weekly Schedule</h3>
          <div style="display:flex;flex-direction:column;gap:1px;background:#222;">
            {coach.hours.map((h) => (
              <div style="display:flex;justify-content:space-between;padding:14px 20px;background:#0D0D0D;">
                <span class="oswald" style="font-size:0.9rem;color:#999;text-transform:uppercase;">{h.day}</span>
                <span class="inter" style="font-size:0.85rem;color:#FF5500;">{h.hours}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- JOIN FORM -->
    <section id="join" style="background:#111;padding:96px 24px;border-top:3px solid #FF5500;">
      <div style="max-width:700px;margin:0 auto;">
        <div style="text-align:center;margin-bottom:16px;">
          <span class="tribe-badge">Free First Class</span>
        </div>
        <h2 class="oswald" style="text-align:center;font-size:clamp(2rem,4vw,3rem);font-weight:700;text-transform:uppercase;color:#fff;margin-bottom:8px;">
          Join the <span style="color:#FF5500;">Blaze Family</span>
        </h2>
        <p class="inter" style="text-align:center;color:#999;margin-bottom:48px;">One form. Zero obligation. We'll reach out with your spot details within the hour.</p>

        <form aria-label="Reserve first free class" style="display:flex;flex-direction:column;gap:16px;" onsubmit="handleJoin(event)">
          <div class="form-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <div>
              <label class="oswald" for="join-name" style="display:block;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;color:#999;margin-bottom:8px;">Full Name</label>
              <input id="join-name" name="name" type="text" placeholder="Marcus Rivera" required autocomplete="name" />
            </div>
            <div>
              <label class="oswald" for="join-email" style="display:block;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;color:#999;margin-bottom:8px;">Email</label>
              <input id="join-email" name="email" type="email" placeholder="you@email.com" required autocomplete="email" />
            </div>
          </div>
          <div class="form-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <div>
              <label class="oswald" for="join-phone" style="display:block;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;color:#999;margin-bottom:8px;">Phone</label>
              <input id="join-phone" name="phone" type="tel" placeholder="(305) 555-0100" autocomplete="tel" />
            </div>
            <div>
              <label class="oswald" for="join-level" style="display:block;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;color:#999;margin-bottom:8px;">Experience Level</label>
              <select id="join-level" name="level">
                <option value="">Select level</option>
                <option value="beginner">Beginner — First time ever</option>
                <option value="some">Some experience — worked out before</option>
                <option value="intermediate">Intermediate — train regularly</option>
                <option value="advanced">Advanced — competitive athlete</option>
              </select>
            </div>
          </div>
          <div>
            <label class="oswald" for="join-session" style="display:block;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;color:#999;margin-bottom:8px;">Preferred Session</label>
            <select id="join-session" name="session">
              <option value="">Any session works</option>
              <option value="mon-530">Monday 5:30 AM</option>
              <option value="mon-630">Monday 6:30 AM</option>
              <option value="tue-600">Tuesday 6:00 AM</option>
              <option value="wed-530">Wednesday 5:30 AM</option>
              <option value="fri-600pm">Friday 6:00 PM</option>
              <option value="sat-700">Saturday 7:00 AM Community WOD</option>
            </select>
          </div>
          <div>
            <label class="oswald" for="join-goal" style="display:block;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;color:#999;margin-bottom:8px;">What's Your Goal? (Optional)</label>
            <textarea id="join-goal" name="goal" rows="3" placeholder="Lose weight, get stronger, find a community, compete in an obstacle race..."></textarea>
          </div>
          <button type="submit" class="cta-btn" style="width:100%;font-size:1.1rem;padding:20px;border:none;cursor:pointer;text-align:center;">
            Reserve My Free Class
          </button>
          <p class="inter" style="text-align:center;font-size:0.75rem;color:#999;">
            No spam. No pressure. Tony or a coach will text you personally to lock in your time.
          </p>
        </form>

        <div id="join-success" style="display:none;text-align:center;padding:48px 24px;background:#0A0A0A;border:2px solid #FF5500;">
          <div style="font-size:3rem;margin-bottom:16px;" aria-hidden="true">&#x1F525;</div>
          <h3 class="oswald" style="font-size:2rem;font-weight:700;text-transform:uppercase;color:#fff;margin-bottom:12px;">You're In, <span style="color:#FF5500;">Blaze.</span></h3>
          <p class="inter" style="color:#AAA;">Check your phone — Tony will text you within the hour to confirm your spot. See you at the fire.</p>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer style="background:#000;border-top:1px solid #1A1A1A;padding:40px 24px;">
      <div style="max-width:1100px;margin:0 auto;display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;gap:24px;">
        <div style="display:flex;align-items:center;gap:12px;">
          <div style="width:32px;height:32px;background:#FF5500;display:flex;align-items:center;justify-content:center;font-family:'Oswald',sans-serif;font-weight:700;font-size:1rem;color:#000;clip-path:polygon(0 0,calc(100% - 5px) 0,100% 100%,5px 100%);" aria-hidden="true">B</div>
          <span class="oswald" style="font-size:1rem;font-weight:700;letter-spacing:0.08em;color:#fff;text-transform:uppercase;">Blaze Bootcamp</span>
        </div>
        <div class="inter" style="font-size:0.8rem;color:#999;">
          {coach.address.street}, {coach.address.city} &middot; {coach.phone} &middot; {coach.email}
        </div>
        <div class="inter" style="font-size:0.75rem;color:#333;">
          &copy; {new Date().getFullYear()} Blaze Bootcamp. All rights reserved.
        </div>
      </div>
      <div class="inter" style="max-width:1100px;margin:16px auto 0;text-align:center;font-size:0.7rem;color:#333;">
        Built by Donovan Crader &middot; <a href="https://dcrader.dev" style="color:#999;text-decoration:none;">dcrader.dev</a>
      </div>
    </footer>

  </main>

  <script is:inline>
    function handleJoin(e) {
      e.preventDefault();
      var form = e.target;
      var success = document.getElementById('join-success');
      form.style.display = 'none';
      success.style.display = 'block';
      success.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  </script>
</BaseLayout>
