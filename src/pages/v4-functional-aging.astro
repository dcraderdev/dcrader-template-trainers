---
import BaseLayout from '../layouts/BaseLayout.astro';
import { coach } from '../data/v4-coach';
---
<BaseLayout
  title={`${coach.name} | ${coach.gym} — Functional Fitness for 50+`}
  description={coach.tagline}
  fontUrl="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,600;1,8..60,400;1,8..60,600&family=Open+Sans:wght@300;400;600;700&display=swap"
  themeColor="#6b8f71"
  ogImage="https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?w=1200&q=80"
>
  <!-- Nav -->
  <nav aria-label="Main navigation" class="sticky top-0 z-50 bg-[#F7F5EF]/96 backdrop-blur-sm border-b border-[#D4C9B0]">
    <div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-16">
      <a href="#main-content" class="font-source text-xl font-semibold text-[#2D3A27]">{coach.gym}</a>
      <div class="hidden md:flex items-center gap-8" style="font-family: 'Open Sans', sans-serif;">
        <a href="#programs" class="text-[#5A6B52] hover:text-[#2D3A27] text-sm transition-colors">Programs</a>
        <a href="#pricing" class="text-[#5A6B52] hover:text-[#2D3A27] text-sm transition-colors">Pricing</a>
        <a href="#coach" class="text-[#5A6B52] hover:text-[#2D3A27] text-sm transition-colors">Dr. Hayes</a>
        <a href="#booking" class="bg-[#4A6741] hover:bg-[#3D5635] text-white px-5 py-2 rounded-lg text-sm font-semibold transition-colors">Free Assessment</a>
      </div>
      <a href="#booking" class="md:hidden bg-[#4A6741] text-white px-4 py-2 rounded-lg text-sm font-semibold">Book</a>
    </div>
  </nav>

  <main id="main-content" style="font-family: 'Open Sans', sans-serif;">
    <!-- Hero -->
    <section class="relative min-h-screen flex items-center overflow-hidden" aria-labelledby="hero-heading">
      <img
        src="https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?auto=format&fit=crop&w=1920&q=80"
        alt="Active older adult exercising outdoors with energy and confidence"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(74,103,65,0.88) 0%, rgba(74,103,65,0.55) 60%, rgba(74,103,65,0.15) 100%);"></div>
      <div class="relative z-10 max-w-7xl mx-auto px-6 py-32">
        <div class="max-w-2xl">
          <p class="text-[#C8D9B8] text-xs uppercase tracking-[0.4em] font-semibold mb-6" style="font-family: 'Open Sans', sans-serif;">Functional Fitness · Ages 50–82 · Denver, CO</p>
          <h1 id="hero-heading" class="font-source text-6xl md:text-7xl font-semibold text-white leading-tight mb-6">
            Move better.<br/>Live fully.<br/><em>Age on your<br/>own terms.</em>
          </h1>
          <p class="text-[#D4E8C8] text-lg leading-relaxed mb-10 max-w-lg">{coach.tagline}</p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#booking" class="bg-white hover:bg-[#F0EDE4] text-[#2D3A27] px-8 py-4 rounded-lg font-semibold text-base transition-all hover:shadow-lg text-center">
              Free Movement Assessment
            </a>
            <a href="#programs" class="border-2 border-white/50 hover:border-white text-white px-8 py-4 rounded-lg font-semibold text-base transition-all text-center">
              Explore Programs
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust bar -->
    <div class="bg-[#2D3A27] py-5">
      <div class="max-w-7xl mx-auto px-6 flex flex-wrap justify-center gap-8 text-[#B8CCA8] text-sm">
        <span>PhD Kinesiology</span>
        <span>NSCA-CSCS</span>
        <span>ACE Senior Fitness Specialist</span>
        <span>NASM Corrective Exercise</span>
        <span>20 Years Experience</span>
      </div>
    </div>

    <!-- Transformations -->
    <section id="transformations" class="bg-[#EEF2E8] py-24" aria-labelledby="trans-heading">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="text-[#6B8F5E] text-xs uppercase tracking-[0.4em] font-semibold mb-3">Client Stories</p>
          <h2 id="trans-heading" class="font-source text-5xl font-semibold text-[#2D3A27]">
            What becomes possible<br/><em>when you train for longevity</em>
          </h2>
          <p class="text-[#5A6B52] mt-4 max-w-xl mx-auto">These aren't dramatic before-and-afters. They're stories of people who reclaimed their lives.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          {coach.transformations.map(t => (
            <article class="bg-white rounded-2xl overflow-hidden shadow-sm border border-[#D4C9B0]">
              <div class="grid grid-cols-2">
                <div class="relative">
                  <img src={t.beforeImg} alt={`${t.name} before working with Dr. Hayes`} class="w-full h-52 object-cover object-top" />
                  <span class="absolute top-3 left-3 bg-[#8A9A7E]/90 text-white text-xs font-semibold px-2 py-1 rounded">Before</span>
                </div>
                <div class="relative">
                  <img src={t.afterImg} alt={`${t.name} after training with Dr. Hayes`} class="w-full h-52 object-cover object-top" />
                  <span class="absolute top-3 right-3 bg-[#4A6741] text-white text-xs font-semibold px-2 py-1 rounded">After</span>
                </div>
              </div>
              <div class="p-6">
                <p class="font-source text-xl font-semibold text-[#2D3A27]">{t.name}</p>
                <p class="text-[#4A6741] font-semibold text-sm mt-1">{t.result}</p>
                <p class="text-[#5A6B52] text-sm mt-3 italic">"{t.quote}"</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Programs -->
    <section id="programs" class="bg-[#F7F5EF] py-24" aria-labelledby="programs-heading">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="text-[#6B8F5E] text-xs uppercase tracking-[0.4em] font-semibold mb-3">Programs</p>
          <h2 id="programs-heading" class="font-source text-5xl font-semibold text-[#2D3A27]">
            Science-backed programming<br/><em>for every stage of life</em>
          </h2>
          <p class="text-[#5A6B52] mt-4 max-w-xl mx-auto">Each program begins with a comprehensive movement assessment. No guesswork — just a plan built around you.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          {coach.programs.map((prog, i) => (
            <div class={`rounded-2xl p-8 border ${i === 1 ? 'bg-[#4A6741] border-[#4A6741]' : 'bg-white border-[#D4C9B0]'}`}>
              <div class="text-4xl mb-5" aria-hidden="true">{prog.icon}</div>
              <h3 class={`font-source text-2xl font-semibold mb-3 ${i === 1 ? 'text-white' : 'text-[#2D3A27]'}`}>{prog.name}</h3>
              <p class={`text-sm leading-relaxed mb-6 ${i === 1 ? 'text-[#C8D9B8]' : 'text-[#5A6B52]'}`}>{prog.description}</p>
              <ul class="space-y-2.5">
                {prog.features.map(f => (
                  <li class={`flex items-start gap-2.5 text-sm ${i === 1 ? 'text-[#D8EAC8]' : 'text-[#4A6741]'}`}>
                    <span class={`font-bold mt-0.5 ${i === 1 ? 'text-[#B8D4A4]' : 'text-[#6B8F5E]'}`} aria-hidden="true">✓</span>
                    {f}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section id="pricing" class="bg-[#EEF2E8] py-24" aria-labelledby="pricing-heading">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="text-[#6B8F5E] text-xs uppercase tracking-[0.4em] font-semibold mb-3">Investment</p>
          <h2 id="pricing-heading" class="font-source text-5xl font-semibold text-[#2D3A27]">Choose your program</h2>
          <p class="text-[#5A6B52] mt-4">Every plan starts with a free movement assessment. No contracts, cancel anytime.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {coach.pricing.map(tier => (
            <div class={`relative rounded-2xl p-8 border ${tier.popular ? 'bg-[#2D3A27] border-[#2D3A27]' : 'bg-white border-[#D4C9B0]'}`}>
              {tier.popular && (
                <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[#8AB87A] text-[#1A2815] text-xs font-bold uppercase tracking-wider px-4 py-1 rounded-full">Most Popular</span>
              )}
              <p class={`text-sm font-semibold uppercase tracking-widest ${tier.popular ? 'text-[#8AB87A]' : 'text-[#6B8F5E]'}`}>{tier.name}</p>
              <p class={`font-source text-5xl font-semibold mt-2 ${tier.popular ? 'text-white' : 'text-[#2D3A27]'}`}>
                ${tier.price}<span class={`text-lg font-normal ${tier.popular ? 'text-[#8AB87A]' : 'text-[#8A9A7E]'}`}>/mo</span>
              </p>
              <ul class="my-7 space-y-3">
                {tier.features.map(f => (
                  <li class={`flex items-start gap-2.5 text-sm ${tier.popular ? 'text-[#C8D9B8]' : 'text-[#4A6741]'}`}>
                    <span class={`font-bold mt-0.5 ${tier.popular ? 'text-[#8AB87A]' : 'text-[#6B8F5E]'}`} aria-hidden="true">✓</span>
                    {f}
                  </li>
                ))}
              </ul>
              <a href="#booking" class={`block text-center py-3 rounded-lg font-semibold transition-colors ${tier.popular ? 'bg-[#8AB87A] hover:bg-[#9ECB8A] text-[#1A2815]' : 'border border-[#8A9A7E] hover:border-[#4A6741] text-[#2D3A27]'}`}>
                Get Started
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Coach Bio -->
    <section id="coach" class="bg-[#F7F5EF] py-24" aria-labelledby="coach-heading">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid md:grid-cols-2 gap-16 items-center">
          <div class="order-2 md:order-1">
            <p class="text-[#6B8F5E] text-xs uppercase tracking-[0.4em] font-semibold mb-3">Your Coach</p>
            <h2 id="coach-heading" class="font-source text-5xl font-semibold text-[#2D3A27] mb-2">{coach.name}</h2>
            <p class="text-[#4A6741] font-semibold text-lg mb-8">{coach.title}</p>
            <p class="text-[#2D3A27] text-lg leading-relaxed mb-4">{coach.bio}</p>
            <p class="text-[#5A6B52] leading-relaxed mb-8">{coach.bioExtended}</p>
            <div class="flex flex-wrap gap-2 mb-8">
              {coach.certifications.map(cert => (
                <span class="bg-[#EEF2E8] text-[#3D5635] text-xs font-semibold px-3 py-1.5 rounded-lg border border-[#C4D4B8]">{cert}</span>
              ))}
            </div>
            <div class="grid grid-cols-2 gap-4">
              {coach.achievements.map(a => (
                <div class="bg-[#EEF2E8] rounded-xl p-5 border border-[#C4D4B8]">
                  <p class="font-source text-3xl font-semibold text-[#2D3A27]">{a.value}</p>
                  <p class="text-[#5A6B52] text-xs mt-1">{a.label}</p>
                </div>
              ))}
            </div>
          </div>
          <div class="order-1 md:order-2 relative">
            <img
              src={coach.photo}
              alt={`${coach.name}, ${coach.title} — founder of ${coach.gym}`}
              class="w-full aspect-[3/4] object-cover rounded-2xl"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section id="testimonials" class="bg-[#EEF2E8] py-24" aria-labelledby="testimonials-heading">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="text-[#6B8F5E] text-xs uppercase tracking-[0.4em] font-semibold mb-3">Hear From Our Clients</p>
          <h2 id="testimonials-heading" class="font-source text-5xl font-semibold text-[#2D3A27]">Lives transformed, not just bodies</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {coach.testimonials.map(t => (
            <blockquote class="bg-white rounded-2xl p-8 border border-[#D4C9B0] shadow-sm">
              <p class="text-[#4A6741] font-source font-semibold text-2xl mb-4">{t.result}</p>
              <p class="text-[#3D4A35] leading-relaxed mb-6 text-sm">{t.text}</p>
              <footer>
                <cite class="not-italic font-source font-semibold text-[#2D3A27] text-lg">{t.name}</cite>
                <p class="text-[#6B8F5E] text-xs mt-0.5">{t.details}</p>
              </footer>
            </blockquote>
          ))}
        </div>
      </div>
    </section>

    <!-- Free Intro CTA -->
    <section class="bg-[#2D3A27] py-28 text-center" aria-labelledby="cta-heading">
      <div class="max-w-2xl mx-auto px-6">
        <p class="text-[#8AB87A] text-xs uppercase tracking-[0.4em] font-semibold mb-6">No Risk</p>
        <h2 id="cta-heading" class="font-source text-5xl md:text-6xl font-semibold text-white mb-6">
          A free movement assessment.<br/><em>No commitment required.</em>
        </h2>
        <p class="text-[#B8CCA8] text-xl mb-10">Discover exactly where you are and where you could be. Dr. Hayes will build your roadmap personally.</p>
        <a href="#booking" class="inline-block bg-[#8AB87A] hover:bg-[#9ECB8A] text-[#1A2815] px-12 py-5 rounded-lg font-bold text-lg transition-all hover:shadow-2xl hover:scale-105">
          Book My Free Assessment
        </a>
      </div>
    </section>

    <!-- Location & Hours -->
    <section id="location" class="bg-[#F7F5EF] py-24" aria-labelledby="location-heading">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid md:grid-cols-2 gap-16">
          <div>
            <p class="text-[#6B8F5E] text-xs uppercase tracking-[0.4em] font-semibold mb-3">Find Us</p>
            <h2 id="location-heading" class="font-source text-4xl font-semibold text-[#2D3A27] mb-8">Location &amp; Hours</h2>
            <address class="not-italic text-[#5A6B52] mb-8 text-sm space-y-2">
              <p class="font-source text-xl font-semibold text-[#2D3A27]">{coach.gym}</p>
              <p class="mt-2">{coach.address.street}</p>
              <p>{coach.address.city}</p>
              <p class="mt-3"><a href={`tel:${coach.phone.replace(/\D/g,'')}`} class="text-[#4A6741] hover:text-[#2D3A27] transition-colors">{coach.phone}</a></p>
              <p><a href={`mailto:${coach.email}`} class="text-[#4A6741] hover:text-[#2D3A27] transition-colors">{coach.email}</a></p>
            </address>
            <h3 class="font-source font-semibold text-[#2D3A27] text-xl mb-4">Session Times</h3>
            <table class="w-full text-sm" aria-label="Training session times">
              <tbody>
                {coach.hours.map(h => (
                  <tr class="border-b border-[#D4C9B0]">
                    <td class="py-3 text-[#2D3A27] font-medium">{h.day}</td>
                    <td class="py-3 text-right text-[#5A6B52]">{h.hours}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <div>
            <img
              src="https://images.unsplash.com/photo-1559582798-678dfc71ccd8?auto=format&fit=crop&w=600&q=80"
              alt="Senior clients training in the Longevity Athletics studio"
              class="w-full aspect-video object-cover rounded-2xl mb-4"
            />
            <div class="bg-[#EEF2E8] rounded-xl p-6 border border-[#C4D4B8]">
              <p class="font-source font-semibold text-[#2D3A27]">Purposefully designed for 50+</p>
              <p class="text-[#5A6B52] text-sm mt-2">Every piece of equipment, every floor surface, and every protocol at Longevity Athletics is chosen with older adults in mind — safety, effectiveness, and joy of movement.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Booking Form -->
    <section id="booking" class="bg-[#EEF2E8] py-24" aria-labelledby="booking-heading">
      <div class="max-w-2xl mx-auto px-6">
        <div class="text-center mb-12">
          <p class="text-[#6B8F5E] text-xs uppercase tracking-[0.4em] font-semibold mb-3">Get Started</p>
          <h2 id="booking-heading" class="font-source text-5xl font-semibold text-[#2D3A27]">Book your free assessment</h2>
          <p class="text-[#5A6B52] mt-4">Dr. Hayes will personally review your intake and contact you within 48 hours.</p>
        </div>
        <form class="space-y-5 bg-white rounded-2xl p-8 shadow-sm border border-[#D4C9B0]" aria-label="Free assessment booking form" novalidate>
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="v4-name" class="block text-[#2D3A27] text-sm font-semibold mb-2">Full Name <span class="text-red-500" aria-label="required">*</span></label>
              <input type="text" id="v4-name" name="name" required autocomplete="name" placeholder="Your name"
                class="w-full border border-[#C4D4B8] text-[#2D3A27] px-4 py-3 rounded-lg focus:border-[#4A6741] focus:ring-2 focus:ring-[#EEF2E8] focus:outline-none transition-all placeholder:text-[#B8CCA8] text-sm" />
            </div>
            <div>
              <label for="v4-email" class="block text-[#2D3A27] text-sm font-semibold mb-2">Email <span class="text-red-500" aria-label="required">*</span></label>
              <input type="email" id="v4-email" name="email" required autocomplete="email" placeholder="you@example.com"
                class="w-full border border-[#C4D4B8] text-[#2D3A27] px-4 py-3 rounded-lg focus:border-[#4A6741] focus:ring-2 focus:ring-[#EEF2E8] focus:outline-none transition-all placeholder:text-[#B8CCA8] text-sm" />
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="v4-phone" class="block text-[#2D3A27] text-sm font-semibold mb-2">Phone</label>
              <input type="tel" id="v4-phone" name="phone" autocomplete="tel" placeholder="(720) 555-0000"
                class="w-full border border-[#C4D4B8] text-[#2D3A27] px-4 py-3 rounded-lg focus:border-[#4A6741] focus:ring-2 focus:ring-[#EEF2E8] focus:outline-none transition-all placeholder:text-[#B8CCA8] text-sm" />
            </div>
            <div>
              <label for="v4-age" class="block text-[#2D3A27] text-sm font-semibold mb-2">Age Range <span class="text-red-500" aria-label="required">*</span></label>
              <select id="v4-age" name="age" required
                class="w-full border border-[#C4D4B8] text-[#2D3A27] px-4 py-3 rounded-lg focus:border-[#4A6741] focus:ring-2 focus:ring-[#EEF2E8] focus:outline-none transition-all text-sm bg-white">
                <option value="">Select age range</option>
                <option value="50-59">50–59</option>
                <option value="60-69">60–69</option>
                <option value="70-79">70–79</option>
                <option value="80+">80+</option>
              </select>
            </div>
          </div>
          <div>
            <label for="v4-goal" class="block text-[#2D3A27] text-sm font-semibold mb-2">Primary Goal <span class="text-red-500" aria-label="required">*</span></label>
            <select id="v4-goal" name="goal" required
              class="w-full border border-[#C4D4B8] text-[#2D3A27] px-4 py-3 rounded-lg focus:border-[#4A6741] focus:ring-2 focus:ring-[#EEF2E8] focus:outline-none transition-all text-sm bg-white">
              <option value="">Select a goal</option>
              <option value="pain-free">Move pain-free</option>
              <option value="strength">Build strength</option>
              <option value="balance">Improve balance &amp; stability</option>
              <option value="cardiovascular">Heart health &amp; endurance</option>
              <option value="weight">Healthy weight management</option>
              <option value="longevity">Optimize longevity</option>
            </select>
          </div>
          <div>
            <label for="v4-conditions" class="block text-[#2D3A27] text-sm font-semibold mb-2">Current health conditions or injuries</label>
            <textarea id="v4-conditions" name="conditions" rows="3" placeholder="Please share any relevant medical history, pain areas, or recent injuries so Dr. Hayes can personalize your assessment..."
              class="w-full border border-[#C4D4B8] text-[#2D3A27] px-4 py-3 rounded-lg focus:border-[#4A6741] focus:ring-2 focus:ring-[#EEF2E8] focus:outline-none transition-all placeholder:text-[#B8CCA8] resize-none text-sm"></textarea>
          </div>
          <button type="submit" class="w-full bg-[#4A6741] hover:bg-[#3D5635] text-white py-4 rounded-lg font-bold text-lg transition-all hover:shadow-lg" style="font-family: 'Open Sans', sans-serif;">
            Book My Free Assessment
          </button>
          <p class="text-center text-[#8A9A7E] text-xs">Dr. Hayes personally reviews every submission. Response within 48 hours.</p>
        </form>
      </div>
    </section>
  </main>

  <footer class="bg-[#2D3A27] py-12">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <p class="font-source text-white text-xl font-semibold">{coach.gym}</p>
      <p class="text-[#6B8F5E] text-xs mt-2">© {new Date().getFullYear()} {coach.gym}. All rights reserved.</p>
      <p class="text-[#3D5635] text-xs mt-2"><a href="/" class="hover:text-[#6B8F5E] transition-colors">← All Templates</a></p>
    </div>
  </footer>
</BaseLayout>
