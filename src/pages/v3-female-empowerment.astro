---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResponsiveImage from '../components/ResponsiveImage.astro';
import TrainerProfilesHero from '../components/trainers/TrainerProfilesHero.astro';
import { coach } from '../data/v3-coach';
const HERO = '/images/shared/photo-1518611012118-696072aa579a';
---
<BaseLayout
  title="Fierce & Free Fitness — Your Strongest Self Starts Here"
  description="Women-only strength coaching in Austin, TX. Cycle-synced programming. No scales, no shame. Book your free intro."
  fontUrl="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600;1,700&family=Lato:wght@300;400;700&display=swap"
  themeColor="#be185d"
  ogImage="/images/shared/photo-1518611012118-696072aa579a-1920.webp"
>
<Fragment slot="head">
  <link
    rel="preload"
    as="image"
    fetchpriority="high"
    type="image/avif"
    imagesrcset={`${HERO}-320.avif 320w, ${HERO}-640.avif 640w, ${HERO}-1024.avif 1024w, ${HERO}-1920.avif 1920w`}
    imagesizes="100vw"
  />
</Fragment>

<style is:inline>
  body { font-family: 'Lato', sans-serif; background: #FDF5F0; color: #3D1F1F; }
  .playfair { font-family: 'Playfair Display', Georgia, serif; }
  .drop-cap::first-letter { font-family: 'Playfair Display', serif; font-size: 3.5rem; font-weight: 700; float: left; line-height: .8; margin: .1rem .5rem 0 0; color: #be185d; }
  .pillar-card { transition: transform .2s, box-shadow .2s; }
  .pillar-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(190,24,93,.12); }
</style>

<!-- NAV -->
<nav aria-label="Main navigation" style="position:sticky;top:0;z-index:50;background:rgba(253,245,240,.96);backdrop-filter:blur(8px);border-bottom:1px solid #fecdd3;">
  <div style="max-width:1152px;margin:0 auto;padding:0 1.5rem;display:flex;align-items:center;justify-content:space-between;height:64px;">
    <a href="#main-content" class="playfair" style="font-size:1.25rem;font-weight:700;color:#881337;text-decoration:none;letter-spacing:-.01em;">Fierce &amp; Free</a>
    <div style="display:flex;align-items:center;gap:2rem;">
      <a href="#pillars" class="nav-link nav-link-hide-mobile" style="color:#9f1239;font-size:.875rem;text-decoration:none;">Our Pillars</a>
      <a href="#programs" class="nav-link nav-link-hide-mobile" style="color:#9f1239;font-size:.875rem;text-decoration:none;">Programs</a>
      <a href="/v3-success-stories" class="nav-link nav-link-hide-mobile" style="color:#9f1239;font-size:.875rem;text-decoration:none;">Stories</a>
      <a href="#retreat" class="nav-link nav-link-hide-mobile" style="color:#9f1239;font-size:.875rem;text-decoration:none;">Retreat</a>
      <a href="#booking" class="cta nav-cta-mobile" style="background:#be185d;color:#fff;font-size:.875rem;font-weight:700;text-decoration:none;padding:.625rem 1.375rem;border-radius:999px;">Free Intro ✦</a>
    </div>
  </div>
</nav>

<main id="main-content">

<!-- ───── HERO (Trainer Profiles component) ───── -->
<TrainerProfilesHero coach={coach} />

<!-- ───── EDITORIAL SPOTLIGHT — supporting module (image + member quote) ───── -->
<section style="position:relative;background:linear-gradient(160deg,rgba(136,19,55,.92) 0%,rgba(190,24,93,.78) 100%);padding:5rem 0;overflow:hidden;" aria-labelledby="spotlight-h2">
  <ResponsiveImage
    src={HERO}
    alt="Strong woman lifting weights with confidence in a studio"
    sizes="100vw"
    loading="eager"
    decoding="async"
    fetchpriority="high"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;opacity:.35;mix-blend-mode:multiply;"
  />
  <div style="position:relative;z-index:1;max-width:1152px;margin:0 auto;padding:0 1.5rem;display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center;">
    <div>
      <p style="font-size:.7rem;letter-spacing:.4em;color:#fecdd3;text-transform:uppercase;font-weight:700;margin:0 0 1rem;">Member Spotlight · Spring 2025</p>
      <h2 id="spotlight-h2" class="playfair" style="font-size:clamp(2rem,4.5vw,3.25rem);font-weight:700;color:#fff;line-height:1.15;margin:0 0 1rem;">
        <em style="color:#fecdd3;">Rachel's</em><br/>7-month strength story.
      </h2>
      <div style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1.5rem;">
        {['🚫 No scales', '💪 No shame', '✦ Women-only space', '🌸 Cycle-synced training'].map(b => (
          <span style="background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.3);color:#fff;font-size:.75rem;font-weight:600;padding:.375rem .75rem;border-radius:999px;">{b}</span>
        ))}
      </div>
      <a href="#booking" style="background:#fff;color:#881337;font-weight:700;font-size:1rem;text-decoration:none;padding:.85rem 2rem;border-radius:999px;display:inline-block;box-shadow:0 4px 20px rgba(0,0,0,.2);">Start Your Story →</a>
    </div>
    <figure style="background:rgba(253,245,240,.94);backdrop-filter:blur(12px);border-radius:1.5rem;padding:2rem;border:1px solid rgba(190,24,93,.2);margin:0;">
      <div style="display:flex;gap:1.25rem;align-items:flex-start;margin-bottom:1.25rem;">
        <img loading="lazy" decoding="async"
          src="/images/shared/photo-1518611012118-696072aa579a-640.webp"
          alt="Rachel — Fierce & Free client, photographed after her 7-month program"
          style="width:5rem;height:5rem;border-radius:50%;object-fit:cover;object-position:center;border:3px solid #fda4af;flex-shrink:0;" />
        <div>
          <p style="font-size:.65rem;letter-spacing:.3em;color:#be185d;text-transform:uppercase;font-weight:700;margin:0 0 .25rem;">Member spotlight</p>
          <p class="playfair" style="font-size:1.05rem;font-weight:700;color:#881337;margin:0;line-height:1.2;">Rachel M.</p>
          <p style="font-size:.75rem;color:#9f4255;margin:.125rem 0 0;">Mom of two · Strong &amp; Sculpted, month 7</p>
        </div>
      </div>
      <blockquote class="playfair" style="font-size:1.15rem;font-weight:500;color:#881337;line-height:1.5;margin:0 0 1rem;font-style:italic;">
        "I came here to lose weight. I stayed because for the first time, training felt like it was built around <em>me</em> — my cycle, my schedule, my voice. I lift heavier than my husband now and I have never been more <strong>at home</strong> in my own body."
      </blockquote>
      <figcaption style="display:flex;justify-content:space-between;align-items:center;border-top:1px solid #fecdd3;padding-top:.875rem;">
        <span style="font-size:.7rem;letter-spacing:.15em;color:#be185d;text-transform:uppercase;font-weight:700;">7-month transformation</span>
        <span style="font-size:.7rem;color:#9f4255;">Photographed Spring 2025</span>
      </figcaption>
    </figure>
  </div>
</section>

<!-- ───── NO SCALES NO SHAME PILLARS ───── -->
<section id="pillars" style="background:#fff8f5;padding:6rem 0;" aria-labelledby="pillars-h2">
  <div style="max-width:1152px;margin:0 auto;padding:0 1.5rem;">
    <div style="text-align:center;margin-bottom:4rem;">
      <p style="font-size:.7rem;letter-spacing:.4em;color:#be185d;text-transform:uppercase;font-weight:700;margin-bottom:.75rem;">The Fierce &amp; Free Way</p>
      <h2 id="pillars-h2" class="playfair" style="font-size:3rem;font-weight:700;color:#881337;line-height:1.2;">We do things differently here.</h2>
      <div style="width:3rem;height:2px;background:#fda4af;margin:1.25rem auto 0;"></div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem;">
      {[
        { icon:'🚫', title:'No Scales, No Shame', body:'We don\'t measure progress in pounds lost. We measure it in weight lifted, mountains climbed, and confidence gained.' },
        { icon:'🌸', title:'Cycle-Synced Training', body:'Your hormones are not the enemy — they\'re a superpower. We train around your cycle, not against it.' },
        { icon:'👑', title:'Women-Only Space', body:'A gym designed for women, by women. From the equipment to the energy — every inch of this space belongs to you.' },
        { icon:'🤝', title:'Community First', body:'Transformation happens in community. 1,200+ women cheering each other on, every single day. Nobody gets left behind.' },
      ].map(p => (
        <div class="pillar-card" style="background:#fff;border-radius:1.5rem;padding:2rem;border:1px solid #fecdd3;text-align:center;">
          <div style="font-size:2.5rem;margin-bottom:1.25rem;">{p.icon}</div>
          <h3 class="playfair" style="font-size:1.125rem;font-weight:700;color:#881337;margin-bottom:.75rem;">{p.title}</h3>
          <p style="font-size:.875rem;color:#6b4250;line-height:1.7;">{p.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ───── TRANSFORMATIONS (asymmetric) ───── -->
<section id="transformations" style="background:#FDF5F0;padding:6rem 0;" aria-labelledby="trans-h2">
  <div style="max-width:1152px;margin:0 auto;padding:0 1.5rem;">
    <div style="display:grid;grid-template-columns:5fr 7fr;gap:4rem;align-items:center;margin-bottom:4rem;">
      <div>
        <p style="font-size:.7rem;letter-spacing:.4em;color:#be185d;text-transform:uppercase;font-weight:700;margin-bottom:.75rem;">Transformations</p>
        <h2 id="trans-h2" class="playfair" style="font-size:3rem;font-weight:700;color:#881337;line-height:1.2;margin-bottom:1.25rem;">
          Beyond the<br/><em>before and after.</em>
        </h2>
        <p style="color:#6b4250;line-height:1.8;">Every client journey is about far more than how a body looks. It's about what that body can do — and how the woman inside it feels about herself.</p>
      </div>
      <div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
          {[coach.transformations[0], coach.transformations[1]].map(t => (
            <article style="background:#fff;border-radius:1.25rem;overflow:hidden;border:1px solid #fecdd3;">
              <div style="display:grid;grid-template-columns:1fr 1fr;">
                <div style="position:relative;">
                  <img loading="lazy" decoding="async" src={t.beforeImg} alt={`${t.name} before — Fierce & Free`} style="width:100%;height:8rem;object-fit:cover;object-position:top;display:block;" />
                  <span style="position:absolute;top:.375rem;left:.375rem;background:#ffe4e6;color:#9f1239;font-size:.6rem;font-weight:700;padding:.2rem .4rem;border-radius:.25rem;">Before</span>
                </div>
                <div style="position:relative;">
                  <img loading="lazy" decoding="async" src={t.afterImg} alt={`${t.name} after — ${t.result}`} style="width:100%;height:8rem;object-fit:cover;object-position:top;display:block;" />
                  <span style="position:absolute;top:.375rem;right:.375rem;background:#be185d;color:#fff;font-size:.6rem;font-weight:700;padding:.2rem .4rem;border-radius:.25rem;">After</span>
                </div>
              </div>
              <div style="padding:.875rem;">
                <p class="playfair" style="font-weight:700;color:#881337;font-size:.9375rem;">{t.name}</p>
                <p style="color:#be185d;font-size:.75rem;font-weight:700;margin:.125rem 0;">{t.result}</p>
                <p style="color:#9f4255;font-size:.75rem;font-style:italic;">"{t.quote}"</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
    <!-- Third transformation — full width editorial -->
    {coach.transformations[2] && (
      <article style="display:grid;grid-template-columns:auto 1fr;gap:2rem;align-items:center;background:#fff;border-radius:1.5rem;padding:2rem;border:1px solid #fecdd3;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;width:280px;flex-shrink:0;">
          <div style="position:relative;">
            <img loading="lazy" decoding="async" src={coach.transformations[2].beforeImg} alt={`${coach.transformations[2].name} before`} style="width:100%;height:10rem;object-fit:cover;border-radius:.75rem;" />
            <span style="position:absolute;top:.5rem;left:.5rem;background:#ffe4e6;color:#9f1239;font-size:.65rem;font-weight:700;padding:.2rem .5rem;border-radius:.375rem;">Before</span>
          </div>
          <div style="position:relative;">
            <img loading="lazy" decoding="async" src={coach.transformations[2].afterImg} alt={`${coach.transformations[2].name} after`} style="width:100%;height:10rem;object-fit:cover;border-radius:.75rem;" />
            <span style="position:absolute;top:.5rem;right:.5rem;background:#be185d;color:#fff;font-size:.65rem;font-weight:700;padding:.2rem .5rem;border-radius:.375rem;">After</span>
          </div>
        </div>
        <div>
          <p class="playfair" style="font-size:1.375rem;font-weight:700;color:#881337;">{coach.transformations[2].name}</p>
          <p style="color:#be185d;font-weight:700;margin:.25rem 0 .75rem;">{coach.transformations[2].result}</p>
          <p style="color:#6b4250;line-height:1.8;font-size:1rem;font-style:italic;">"{coach.transformations[2].quote}"</p>
        </div>
      </article>
    )}
  </div>
</section>

<!-- ───── PROGRAMS ───── -->
<section id="programs" style="background:#fff8f5;padding:6rem 0;" aria-labelledby="programs-h2">
  <div style="max-width:1152px;margin:0 auto;padding:0 1.5rem;">
    <div style="text-align:center;margin-bottom:4rem;">
      <p style="font-size:.7rem;letter-spacing:.4em;color:#be185d;text-transform:uppercase;font-weight:700;margin-bottom:.75rem;">Training Programs</p>
      <h2 id="programs-h2" class="playfair" style="font-size:3rem;font-weight:700;color:#881337;">Programming built<br/><em>for your body.</em></h2>
      <p style="color:#6b4250;max-width:36rem;margin:.75rem auto 0;line-height:1.7;">Not a scaled-down version of a man's program. Built from the ground up for women's physiology, hormones, and goals.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;">
      {coach.programs.map((prog, i) => (
        <div style={`border-radius:1.5rem;padding:2.5rem;border:1px solid #fecdd3;background:${i===1?'#be185d':'#fff'};position:relative;overflow:hidden;`}>
          {i===1 && <div style="position:absolute;top:0;right:0;width:8rem;height:8rem;background:rgba(255,255,255,.06);border-radius:50%;transform:translate(3rem,-3rem);pointer-events:none;"></div>}
          <div style="font-size:2.5rem;margin-bottom:1.25rem;">{prog.icon}</div>
          <h3 class="playfair" style={`font-size:1.5rem;font-weight:700;margin-bottom:.625rem;color:${i===1?'#fff':'#881337'};`}>{prog.name}</h3>
          <p style={`font-size:.875rem;line-height:1.7;margin-bottom:1.5rem;color:${i===1?'#fecdd3':'#6b4250'};`}>{prog.description}</p>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.625rem;">
            {prog.features.map(f => (
              <li style={`display:flex;align-items:flex-start;gap:.5rem;font-size:.8125rem;color:${i===1?'#ffe4e6':'#6b4250'};`}>
                <span style={`font-weight:700;margin-top:1px;flex-shrink:0;color:${i===1?'#fda4af':'#be185d'};`}>✦</span>{f}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ───── PRICING ───── -->
<section id="pricing" style="background:#FDF5F0;padding:6rem 0;" aria-labelledby="pricing-h2">
  <div style="max-width:1152px;margin:0 auto;padding:0 1.5rem;">
    <div style="text-align:center;margin-bottom:4rem;">
      <p style="font-size:.7rem;letter-spacing:.4em;color:#be185d;text-transform:uppercase;font-weight:700;margin-bottom:.75rem;">Membership</p>
      <h2 id="pricing-h2" class="playfair" style="font-size:3rem;font-weight:700;color:#881337;">Choose your path.</h2>
      <p style="color:#6b4250;margin-top:.75rem;">First session always free. No contracts. Cancel anytime.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;max-width:56rem;margin:0 auto;">
      {coach.pricing.map(tier => (
        <div style={`position:relative;border-radius:1.5rem;padding:2.5rem;border:${tier.popular?'2px solid #be185d':'1px solid #fecdd3'};background:${tier.popular?'#881337':'#fff'};`}>
          {tier.popular && <span class="playfair" style="position:absolute;top:-1rem;left:50%;transform:translateX(-50%);background:#fda4af;color:#881337;font-size:.8rem;font-weight:700;padding:.375rem 1.25rem;border-radius:999px;white-space:nowrap;font-style:italic;">Most Loved ✦</span>}
          <p style={`font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:${tier.popular?'#fda4af':'#be185d'};margin-bottom:.625rem;`}>{tier.name}</p>
          <p class="playfair" style={`font-size:3.5rem;font-weight:700;line-height:1;color:${tier.popular?'#fff':'#881337'};`}>${tier.price}<span style={`font-size:1.125rem;font-weight:400;color:${tier.popular?'#fda4af':'#be185d'};`}>/mo</span></p>
          <div style={`border-top:1px solid ${tier.popular?'rgba(255,255,255,.15)':'#fecdd3'};margin:1.5rem 0;padding-top:1.5rem;`}>
            <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.75rem;">
              {tier.features.map(f => (
                <li style={`display:flex;align-items:flex-start;gap:.5rem;font-size:.8125rem;color:${tier.popular?'#fecdd3':'#6b4250'};`}>
                  <span style={`font-weight:700;flex-shrink:0;margin-top:1px;color:${tier.popular?'#fda4af':'#be185d'};`}>✦</span>{f}
                </li>
              ))}
            </ul>
          </div>
          <a href="#booking" style={`display:block;text-align:center;padding:.875rem;border-radius:999px;font-weight:700;font-size:.9375rem;text-decoration:none;background:${tier.popular?'#fff':'#ffe4e6'};color:${tier.popular?'#881337':'#be185d'};`}>
            Start Free Session
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ───── RETREAT CTA ───── -->
<section id="retreat" style="position:relative;padding:6rem 0;overflow:hidden;background:#881337;" aria-labelledby="retreat-h2">
  <img loading="lazy" decoding="async" src="/images/shared/photo-1506629082955-511b1aa562c8-1920.webp"
    alt="Women doing yoga together in a beautiful outdoor setting" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(136,19,55,.88) 0%,rgba(190,24,93,.6) 100%);"></div>
  <div style="position:relative;z-index:10;max-width:1152px;margin:0 auto;padding:0 1.5rem;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;">
    <div>
      <p style="font-size:.7rem;letter-spacing:.4em;color:#fecdd3;text-transform:uppercase;font-weight:700;margin-bottom:1rem;">Annual Women's Retreat</p>
      <h2 id="retreat-h2" class="playfair" style="font-size:3rem;font-weight:700;color:#fff;line-height:1.2;margin-bottom:1.25rem;">
        Fierce &amp; Free<br/><em>Retreat 2026</em>
      </h2>
      <p style="color:#fecdd3;line-height:1.8;margin-bottom:2rem;">Four days in the Texas Hill Country. Strength training, yoga, nutrition workshops, and the kind of deep connection you can only find when 40 women commit to growing together. Flourish members get first access.</p>
      <div style="display:flex;gap:2rem;margin-bottom:2rem;">
        <div>
          <p class="playfair" style="font-size:2rem;font-weight:700;color:#fff;">Oct 2026</p>
          <p style="color:#fecdd3;font-size:.8rem;">Dates TBA</p>
        </div>
        <div>
          <p class="playfair" style="font-size:2rem;font-weight:700;color:#fff;">40</p>
          <p style="color:#fecdd3;font-size:.8rem;">Spots available</p>
        </div>
        <div>
          <p class="playfair" style="font-size:2rem;font-weight:700;color:#fff;">Hill Country</p>
          <p style="color:#fecdd3;font-size:.8rem;">Texas</p>
        </div>
      </div>
      <a href="#booking" style="background:#fff;color:#881337;font-weight:700;font-size:1rem;text-decoration:none;padding:1rem 2.25rem;border-radius:999px;display:inline-block;">Join Waitlist for 2026</a>
    </div>
    <div style="background:rgba(253,245,240,.12);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.2);border-radius:1.5rem;padding:2.5rem;">
      <p class="playfair" style="font-size:1.25rem;font-weight:600;color:#fff;margin-bottom:1.5rem;font-style:italic;">What's included:</p>
      <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:1rem;">
        {['4 nights accommodation in the Hill Country','Daily strength training sessions','Morning yoga &amp; mobility','Nutrition workshop &amp; cooking class','Group hike &amp; outdoor adventure','Evening community bonfire','Private coaching consultations'].map(item => (
          <li style="display:flex;align-items:flex-start;gap:.75rem;color:#fecdd3;font-size:.875rem;">
            <span style="color:#fecdd3;font-weight:700;flex-shrink:0;">✦</span>
            <span set:html={item}></span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<!-- ───── COACH ───── -->
<section id="coach" style="background:#fff8f5;padding:6rem 0;" aria-labelledby="coach-h2">
  <div style="max-width:1152px;margin:0 auto;padding:0 1.5rem;display:grid;grid-template-columns:7fr 5fr;gap:4rem;align-items:center;">
    <div>
      <p style="font-size:.7rem;letter-spacing:.4em;color:#be185d;text-transform:uppercase;font-weight:700;margin-bottom:.75rem;">Meet Amanda</p>
      <h2 id="coach-h2" class="playfair" style="font-size:3.5rem;font-weight:700;color:#881337;line-height:1.1;margin-bottom:.5rem;">{coach.name}</h2>
      <p style="color:#be185d;font-weight:700;font-size:1.125rem;margin-bottom:2rem;">{coach.title}</p>
      <p class="drop-cap" style="color:#3D1F1F;line-height:1.8;margin-bottom:1rem;">{coach.bio}</p>
      <p style="color:#6b4250;line-height:1.8;margin-bottom:2rem;">{coach.bioExtended}</p>
      <div style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:2rem;">
        {coach.certifications.map(c => (
          <span style="background:#ffe4e6;color:#881337;font-size:.75rem;font-weight:700;padding:.375rem .875rem;border-radius:999px;">{c}</span>
        ))}
      </div>
    </div>
    <div style="position:relative;">
      <img loading="lazy" decoding="async" src={coach.photo} alt={`${coach.name} — ${coach.title}, founder of Fierce & Free`} style="width:100%;aspect-ratio:3/4;object-fit:cover;border-radius:2rem;display:block;" />
      <!-- Pull quote overlay -->
      <div style="position:absolute;bottom:-1.5rem;left:-1.5rem;background:#fff;border:1px solid #fecdd3;border-radius:1.25rem;padding:1.5rem;max-width:16rem;box-shadow:0 8px 32px rgba(190,24,93,.12);">
        <p class="playfair" style="font-size:.9rem;color:#881337;font-style:italic;line-height:1.6;">"Every woman deserves programming that honors her body."</p>
        <p style="color:#be185d;font-size:.75rem;font-weight:700;margin-top:.75rem;">— Amanda Torres</p>
      </div>
    </div>
  </div>
</section>

<!-- ───── TESTIMONIALS (editorial hero quote + 2 mini cards) ───── -->
<section id="testimonials" style="background:#be185d;padding:6rem 0;position:relative;overflow:hidden;" aria-labelledby="test-h2">
  <div aria-hidden="true" style="position:absolute;top:2rem;left:50%;transform:translateX(-50%);font-family:'Playfair Display',serif;font-size:24rem;line-height:1;color:rgba(255,255,255,.05);pointer-events:none;user-select:none;">"</div>
  <div style="position:relative;z-index:1;max-width:1152px;margin:0 auto;padding:0 1.5rem;">
    <div style="text-align:center;margin-bottom:3.5rem;">
      <p style="font-size:.7rem;letter-spacing:.4em;color:#fecdd3;text-transform:uppercase;font-weight:700;margin-bottom:.75rem;">In Their Words</p>
      <h2 id="test-h2" class="playfair" style="font-size:3rem;font-weight:700;color:#fff;">The community<br/><em>speaks.</em></h2>
    </div>
    <!-- Featured hero quote -->
    {coach.testimonials[0] && (
      <figure style="margin:0 0 2.5rem;text-align:center;max-width:48rem;margin-left:auto;margin-right:auto;">
        <blockquote class="playfair" style="font-size:clamp(1.5rem,3vw,2.25rem);font-weight:500;color:#fff;line-height:1.4;font-style:italic;margin:0 0 1.75rem;">
          "{coach.testimonials[0].text}"
        </blockquote>
        <div style="width:3rem;height:2px;background:#fda4af;margin:0 auto 1rem;"></div>
        <figcaption style="display:flex;flex-direction:column;align-items:center;gap:.25rem;">
          <cite class="playfair" style="font-size:1.25rem;font-weight:700;color:#fff;font-style:normal;">{coach.testimonials[0].name}</cite>
          <p style="color:#fecdd3;font-size:.8125rem;letter-spacing:.05em;">{coach.testimonials[0].details} · <span style="font-weight:700;">{coach.testimonials[0].result}</span></p>
        </figcaption>
      </figure>
    )}
    <!-- Supporting mini quotes -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;max-width:48rem;margin:0 auto;">
      {coach.testimonials.slice(1).map(t => (
        <blockquote style="background:rgba(253,245,240,.08);border-left:3px solid #fda4af;border-radius:0 1rem 1rem 0;padding:1.5rem 1.75rem;margin:0;">
          <p style="color:#ffe4e6;font-size:.9375rem;line-height:1.7;margin:0 0 1rem;font-style:italic;">"{t.text}"</p>
          <footer style="display:flex;justify-content:space-between;align-items:baseline;gap:1rem;">
            <cite class="playfair" style="font-size:1rem;font-weight:700;color:#fff;font-style:italic;">— {t.name}</cite>
            <span class="playfair" style="font-size:1.125rem;font-weight:700;color:#fecdd3;font-style:italic;">{t.result}</span>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>

<!-- ───── LOCATION ───── -->
<section id="location" style="background:#FDF5F0;padding:6rem 0;" aria-labelledby="loc-h2">
  <div style="max-width:1152px;margin:0 auto;padding:0 1.5rem;display:grid;grid-template-columns:1fr 1fr;gap:4rem;">
    <div>
      <p style="font-size:.7rem;letter-spacing:.4em;color:#be185d;text-transform:uppercase;font-weight:700;margin-bottom:.75rem;">Visit Us</p>
      <h2 id="loc-h2" class="playfair" style="font-size:2.5rem;font-weight:700;color:#881337;margin-bottom:2rem;">Location &amp; Studio Hours</h2>
      <address style="font-style:normal;color:#6b4250;margin-bottom:2rem;line-height:2.2;">
        <p class="playfair" style="font-size:1.25rem;font-weight:700;color:#881337;">{coach.gym}</p>
        <p>{coach.address.street}</p>
        <p>{coach.address.city}</p>
        <p style="margin-top:.625rem;"><a href={`tel:${coach.phone.replace(/\D/g,'')}`} style="color:#be185d;text-decoration:none;font-weight:700;">{coach.phone}</a></p>
        <p><a href={`mailto:${coach.email}`} style="color:#be185d;text-decoration:none;font-weight:700;">{coach.email}</a></p>
      </address>
      <table style="width:100%;border-collapse:collapse;" aria-label="Studio hours">
        <tbody>
          {coach.hours.map(h => (
            <tr style="border-bottom:1px solid #fecdd3;">
              <td style="padding:.875rem 0;color:#3D1F1F;font-weight:600;">{h.day}</td>
              <td style="padding:.875rem 0;text-align:right;color:#be185d;font-weight:700;">{h.hours}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <div>
      <img loading="lazy" decoding="async" src="/images/shared/photo-1552674605-db6ffd4facb5-1920.webp"
        alt="Women celebrating together in the Fierce and Free studio" style="width:100%;aspect-ratio:4/3;object-fit:cover;border-radius:1.5rem;display:block;margin-bottom:1rem;" />
      <div style="background:#fff;border-radius:1.25rem;padding:1.5rem;border:1px solid #fecdd3;">
        <p class="playfair" style="font-weight:700;color:#881337;margin-bottom:.375rem;">A space made for you.</p>
        <p style="color:#6b4250;font-size:.875rem;line-height:1.6;">Women-only training floor, private changing area, nursing room, and a community corner where bonds are forged between sessions.</p>
      </div>
    </div>
  </div>
</section>

<!-- ───── BOOKING ───── -->
<section id="booking" style="background:#fff8f5;padding:6rem 0;" aria-labelledby="book-h2">
  <div style="max-width:40rem;margin:0 auto;padding:0 1.5rem;">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <p style="font-size:.7rem;letter-spacing:.4em;color:#be185d;text-transform:uppercase;font-weight:700;margin-bottom:.75rem;">Begin</p>
      <h2 id="book-h2" class="playfair" style="font-size:3rem;font-weight:700;color:#881337;margin-bottom:.75rem;">Book your free intro.</h2>
      <p style="color:#6b4250;">Amanda personally reviews every submission and responds within 24 hours.</p>
    </div>
    <form style="background:#fff;border-radius:1.5rem;padding:2.5rem;border:1px solid #fecdd3;display:flex;flex-direction:column;gap:1.25rem;box-shadow:0 4px 24px rgba(190,24,93,.08);" aria-label="Free intro session booking" novalidate>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;">
        <div>
          <label for="v3-name" style="display:block;font-size:.8125rem;font-weight:700;color:#3D1F1F;margin-bottom:.375rem;">Full Name <span aria-label="required" style="color:#be185d;">*</span></label>
          <input type="text" id="v3-name" name="name" required autocomplete="name" placeholder="Your name"
            style="width:100%;border:1.5px solid #fecdd3;color:#3D1F1F;padding:.75rem 1rem;border-radius:.75rem;font-size:.9375rem;outline:none;box-sizing:border-box;font-family:'Lato',sans-serif;" />
        </div>
        <div>
          <label for="v3-email" style="display:block;font-size:.8125rem;font-weight:700;color:#3D1F1F;margin-bottom:.375rem;">Email <span aria-label="required" style="color:#be185d;">*</span></label>
          <input type="email" id="v3-email" name="email" required autocomplete="email" placeholder="you@example.com"
            style="width:100%;border:1.5px solid #fecdd3;color:#3D1F1F;padding:.75rem 1rem;border-radius:.75rem;font-size:.9375rem;outline:none;box-sizing:border-box;font-family:'Lato',sans-serif;" />
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;">
        <div>
          <label for="v3-phone" style="display:block;font-size:.8125rem;font-weight:700;color:#3D1F1F;margin-bottom:.375rem;">Phone</label>
          <input type="tel" id="v3-phone" name="phone" autocomplete="tel" placeholder="(512) 555-0000"
            style="width:100%;border:1.5px solid #fecdd3;color:#3D1F1F;padding:.75rem 1rem;border-radius:.75rem;font-size:.9375rem;outline:none;box-sizing:border-box;font-family:'Lato',sans-serif;" />
        </div>
        <div>
          <label for="v3-goal" style="display:block;font-size:.8125rem;font-weight:700;color:#3D1F1F;margin-bottom:.375rem;">Your Goal <span aria-label="required" style="color:#be185d;">*</span></label>
          <select id="v3-goal" name="goal" required style="width:100%;border:1.5px solid #fecdd3;color:#3D1F1F;padding:.75rem 1rem;border-radius:.75rem;font-size:.9375rem;outline:none;background:#fff;box-sizing:border-box;font-family:'Lato',sans-serif;">
            <option value="">Choose a goal</option>
            <option value="strength">Build strength &amp; confidence</option>
            <option value="fat-loss">Lose weight sustainably</option>
            <option value="postnatal">Postnatal recovery</option>
            <option value="hormones">Hormone health &amp; energy</option>
            <option value="community">Find my community</option>
          </select>
        </div>
      </div>
      <div>
        <label for="v3-experience" style="display:block;font-size:.8125rem;font-weight:700;color:#3D1F1F;margin-bottom:.375rem;">Training background</label>
        <select id="v3-experience" name="experience" style="width:100%;border:1.5px solid #fecdd3;color:#3D1F1F;padding:.75rem 1rem;border-radius:.75rem;font-size:.9375rem;outline:none;background:#fff;box-sizing:border-box;font-family:'Lato',sans-serif;">
          <option value="none">Complete beginner</option>
          <option value="some">Some experience</option>
          <option value="returning">Returning after a break</option>
          <option value="experienced">Experienced lifter</option>
        </select>
      </div>
      <div>
        <label for="v3-msg" style="display:block;font-size:.8125rem;font-weight:700;color:#3D1F1F;margin-bottom:.375rem;">Share your story</label>
        <textarea id="v3-msg" name="message" rows="4" placeholder="Where are you in your journey? What do you dream of achieving? What's held you back?"
          style="width:100%;border:1.5px solid #fecdd3;color:#3D1F1F;padding:.75rem 1rem;border-radius:.75rem;font-size:.9375rem;outline:none;resize:none;box-sizing:border-box;font-family:'Lato',sans-serif;"></textarea>
      </div>
      <button type="submit" style="background:#be185d;color:#fff;font-weight:700;font-size:1.0625rem;border:none;padding:1.1rem;border-radius:999px;cursor:pointer;width:100%;font-family:'Lato',sans-serif;">
        Book My Free Intro Session ✦
      </button>
      <p style="text-align:center;color:#be185d;font-size:.75rem;">All women welcome. No judgment. No pressure.</p>
    </form>
  </div>
</section>

</main>

<footer style="background:#881337;padding:3rem 1.5rem;text-align:center;">
  <p class="playfair" style="color:#fff;font-size:1.25rem;font-weight:700;font-style:italic;">{coach.gym}</p>
  <p style="color:#fecdd3;font-size:.75rem;margin-top:.5rem;">© {new Date().getFullYear()} {coach.gym} · Austin, TX · All rights reserved.</p>
  <p style="margin-top:.5rem;"><a href="/" style="color:#fecdd3;font-size:.75rem;text-decoration:none;">← All Templates</a></p>
  <p style="color:#fecdd3;font-size:.7rem;margin-top:.75rem;">Built by Donovan Crader · <a href="https://dcrader.dev" style="color:#fecdd3;text-decoration:none;">dcrader.dev</a></p>
</footer>

</BaseLayout>
