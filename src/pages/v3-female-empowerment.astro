---
import BaseLayout from '../layouts/BaseLayout.astro';
import { coach } from '../data/v3-coach';
---
<BaseLayout
  title={`${coach.name} | ${coach.gym} — Women's Strength Coaching`}
  description={coach.tagline}
  fontUrl="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Lato:wght@300;400;700&display=swap"
  themeColor="#be185d"
  ogImage="https://images.unsplash.com/photo-1518611012118-696072aa579a?w=1200&q=80"
>
  <!-- Nav -->
  <nav aria-label="Main navigation" class="sticky top-0 z-50 bg-[#FDF5F0]/95 backdrop-blur-sm border-b border-rose-100">
    <div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-16">
      <a href="#main-content" class="font-playfair text-xl font-bold text-rose-900">{coach.gym}</a>
      <div class="hidden md:flex items-center gap-8">
        <a href="#programs" class="text-rose-600 hover:text-rose-900 text-sm font-medium transition-colors" style="font-family: 'Lato', sans-serif;">Programs</a>
        <a href="#pricing" class="text-rose-600 hover:text-rose-900 text-sm font-medium transition-colors" style="font-family: 'Lato', sans-serif;">Pricing</a>
        <a href="#coach" class="text-rose-600 hover:text-rose-900 text-sm font-medium transition-colors" style="font-family: 'Lato', sans-serif;">Amanda</a>
        <a href="#booking" class="bg-rose-700 hover:bg-rose-800 text-white px-5 py-2 rounded-full text-sm font-semibold transition-colors" style="font-family: 'Lato', sans-serif;">Free Intro</a>
      </div>
      <a href="#booking" class="md:hidden bg-rose-700 text-white px-4 py-2 rounded-full text-sm font-semibold">Join</a>
    </div>
  </nav>

  <main id="main-content" style="font-family: 'Lato', sans-serif;">
    <!-- Hero -->
    <section class="relative min-h-screen flex items-center overflow-hidden" aria-labelledby="hero-heading">
      <img
        src="https://images.unsplash.com/photo-1518611012118-696072aa579a?auto=format&fit=crop&w=1920&q=80"
        alt="Strong woman confidently lifting weights in a well-lit studio"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(190,24,93,0.75) 0%, rgba(253,245,240,0.60) 100%);"></div>
      <div class="relative z-10 max-w-7xl mx-auto px-6 py-32">
        <div class="max-w-2xl">
          <p class="text-rose-100 text-xs uppercase tracking-[0.4em] font-semibold mb-6">Women's Strength · Austin, TX</p>
          <h1 id="hero-heading" class="font-playfair text-6xl md:text-8xl font-bold text-white leading-tight mb-6">
            Strong.<br/>Fierce.<br/><em>Unapologetically<br/>you.</em>
          </h1>
          <p class="text-rose-50 text-lg leading-relaxed mb-10 max-w-lg">{coach.tagline}</p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#booking" class="bg-white hover:bg-rose-50 text-rose-800 px-8 py-4 rounded-full font-bold text-base transition-all hover:shadow-lg text-center">
              Start Your Journey
            </a>
            <a href="#programs" class="border-2 border-white/60 hover:border-white text-white px-8 py-4 rounded-full font-semibold text-base transition-all text-center">
              Explore Programs
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Marquee stats -->
    <div class="bg-rose-800 py-5 overflow-hidden">
      <div class="flex flex-wrap justify-center gap-8 text-rose-100 text-sm font-semibold px-6">
        {coach.achievements.map(a => (
          <span>{a.value} <span class="text-rose-300">{a.label}</span></span>
        ))}
        <span>Pre/Postnatal Certified</span>
        <span>Cycle-Synced Training</span>
      </div>
    </div>

    <!-- Transformations -->
    <section id="transformations" class="bg-rose-50 py-24" aria-labelledby="trans-heading">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="text-rose-400 text-xs uppercase tracking-[0.4em] font-semibold mb-3">Their Words</p>
          <h2 id="trans-heading" class="font-playfair text-5xl font-bold text-rose-900">Transformations that go<br/><em>beyond the scale</em></h2>
          <p class="text-rose-600 mt-4 max-w-xl mx-auto">Strength isn't just physical. Watch what happens when women finally train for themselves.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          {coach.transformations.map(t => (
            <article class="bg-white rounded-3xl overflow-hidden shadow-sm border border-rose-100">
              <div class="grid grid-cols-2">
                <div class="relative">
                  <img src={t.beforeImg} alt={`${t.name} before training with Amanda Torres`} class="w-full h-52 object-cover object-top" />
                  <span class="absolute top-3 left-3 bg-rose-100 text-rose-700 text-xs font-semibold px-2 py-1 rounded-full">Before</span>
                </div>
                <div class="relative">
                  <img src={t.afterImg} alt={`${t.name} after training with Amanda Torres`} class="w-full h-52 object-cover object-top" />
                  <span class="absolute top-3 right-3 bg-rose-700 text-white text-xs font-semibold px-2 py-1 rounded-full">After</span>
                </div>
              </div>
              <div class="p-6">
                <p class="font-playfair text-xl font-bold text-rose-900">{t.name}</p>
                <p class="text-rose-600 font-semibold text-sm mt-1">{t.result}</p>
                <p class="text-rose-400 text-sm mt-3 italic">"{t.quote}"</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Programs -->
    <section id="programs" class="bg-[#FDF5F0] py-24" aria-labelledby="programs-heading">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="text-rose-400 text-xs uppercase tracking-[0.4em] font-semibold mb-3">Training Programs</p>
          <h2 id="programs-heading" class="font-playfair text-5xl font-bold text-rose-900">Programming built for<br/><em>your body</em></h2>
          <p class="text-rose-600 mt-4 max-w-xl mx-auto">Not a scaled-down version of a man's program. Designed from the ground up for women's physiology.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          {coach.programs.map((prog, i) => (
            <div class={`rounded-3xl p-8 border ${i === 1 ? 'bg-rose-700 text-white border-rose-700' : 'bg-white border-rose-100'}`}>
              <div class="text-4xl mb-5" aria-hidden="true">{prog.icon}</div>
              <h3 class={`font-playfair text-2xl font-bold mb-3 ${i === 1 ? 'text-white' : 'text-rose-900'}`}>{prog.name}</h3>
              <p class={`text-sm leading-relaxed mb-6 ${i === 1 ? 'text-rose-200' : 'text-rose-600'}`}>{prog.description}</p>
              <ul class="space-y-2.5">
                {prog.features.map(f => (
                  <li class={`flex items-start gap-2.5 text-sm ${i === 1 ? 'text-rose-100' : 'text-rose-700'}`}>
                    <span class={`font-bold mt-0.5 ${i === 1 ? 'text-rose-200' : 'text-rose-400'}`} aria-hidden="true">✦</span>
                    {f}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section id="pricing" class="bg-rose-50 py-24" aria-labelledby="pricing-heading">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="text-rose-400 text-xs uppercase tracking-[0.4em] font-semibold mb-3">Investment</p>
          <h2 id="pricing-heading" class="font-playfair text-5xl font-bold text-rose-900">Choose your path</h2>
          <p class="text-rose-600 mt-4">Every plan includes your first session free. No contracts, cancel anytime.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {coach.pricing.map(tier => (
            <div class={`relative rounded-3xl p-8 border ${tier.popular ? 'bg-rose-800 border-rose-800' : 'bg-white border-rose-100'}`}>
              {tier.popular && (
                <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-rose-300 text-rose-900 text-xs font-bold uppercase tracking-wider px-4 py-1 rounded-full">Most Loved</span>
              )}
              <p class={`text-sm font-bold uppercase tracking-widest ${tier.popular ? 'text-rose-200' : 'text-rose-400'}`}>{tier.name}</p>
              <p class={`font-playfair text-5xl font-bold mt-2 ${tier.popular ? 'text-white' : 'text-rose-900'}`}>
                ${tier.price}<span class={`text-lg font-normal ${tier.popular ? 'text-rose-300' : 'text-rose-400'}`}>/mo</span>
              </p>
              <ul class="my-7 space-y-3">
                {tier.features.map(f => (
                  <li class={`flex items-start gap-2.5 text-sm ${tier.popular ? 'text-rose-100' : 'text-rose-700'}`}>
                    <span class={`font-bold mt-0.5 ${tier.popular ? 'text-rose-300' : 'text-rose-400'}`} aria-hidden="true">✦</span>
                    {f}
                  </li>
                ))}
              </ul>
              <a href="#booking" class={`block text-center py-3 rounded-full font-semibold transition-colors ${tier.popular ? 'bg-white hover:bg-rose-50 text-rose-800' : 'bg-rose-100 hover:bg-rose-200 text-rose-800'}`}>
                Start Free Session
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Coach Bio -->
    <section id="coach" class="bg-[#FDF5F0] py-24" aria-labelledby="coach-heading">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid md:grid-cols-2 gap-16 items-center">
          <div class="relative">
            <img
              src={coach.photo}
              alt={`${coach.name}, ${coach.title} — founder of ${coach.gym}`}
              class="w-full aspect-[3/4] object-cover rounded-3xl"
            />
            <div class="absolute -bottom-6 -right-6 bg-white rounded-3xl p-6 shadow-lg border border-rose-100 max-w-xs">
              <p class="font-playfair text-rose-900 font-bold">"Every woman deserves programming that honors her body."</p>
              <p class="text-rose-500 text-sm mt-2">— Amanda Torres</p>
            </div>
          </div>
          <div class="pt-8 md:pt-0">
            <p class="text-rose-400 text-xs uppercase tracking-[0.4em] font-semibold mb-3">Meet Amanda</p>
            <h2 id="coach-heading" class="font-playfair text-5xl font-bold text-rose-900 mb-2">{coach.name}</h2>
            <p class="text-rose-500 font-semibold text-lg mb-8">{coach.title}</p>
            <p class="text-rose-800 text-lg leading-relaxed mb-4">{coach.bio}</p>
            <p class="text-rose-600 leading-relaxed mb-8">{coach.bioExtended}</p>
            <div class="flex flex-wrap gap-2 mb-8">
              {coach.certifications.map(cert => (
                <span class="bg-rose-100 text-rose-700 text-xs font-semibold px-3 py-1.5 rounded-full">{cert}</span>
              ))}
            </div>
            <div class="grid grid-cols-2 gap-4">
              {coach.achievements.map(a => (
                <div class="bg-rose-50 rounded-2xl p-5 border border-rose-100">
                  <p class="font-playfair text-3xl font-bold text-rose-800">{a.value}</p>
                  <p class="text-rose-500 text-xs mt-1">{a.label}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section id="testimonials" class="bg-rose-800 py-24" aria-labelledby="testimonials-heading">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="text-rose-300 text-xs uppercase tracking-[0.4em] font-semibold mb-3">The Community Speaks</p>
          <h2 id="testimonials-heading" class="font-playfair text-5xl font-bold text-white">Stories of strength</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {coach.testimonials.map(t => (
            <blockquote class="bg-rose-700/50 rounded-3xl p-8 border border-rose-600/40">
              <p class="text-rose-200 font-semibold text-2xl font-playfair mb-4">{t.result}</p>
              <p class="text-rose-100 leading-relaxed mb-6 text-sm">{t.text}</p>
              <footer>
                <cite class="not-italic font-playfair font-bold text-white text-lg">{t.name}</cite>
                <p class="text-rose-300 text-xs mt-0.5">{t.details}</p>
              </footer>
            </blockquote>
          ))}
        </div>
      </div>
    </section>

    <!-- Free Intro CTA -->
    <section class="relative overflow-hidden py-32" aria-labelledby="cta-heading">
      <img
        src="https://images.unsplash.com/photo-1552674605-db6ffd4facb5?auto=format&fit=crop&w=1920&q=80"
        alt="Group of women celebrating after a workout together"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-rose-900/80"></div>
      <div class="relative z-10 text-center max-w-2xl mx-auto px-6">
        <h2 id="cta-heading" class="font-playfair text-6xl md:text-7xl font-bold text-white mb-6">
          Your first session<br/><em>is on us.</em>
        </h2>
        <p class="text-rose-200 text-xl mb-10">Come as you are. Leave stronger than you imagined. No strings attached.</p>
        <a href="#booking" class="inline-block bg-white hover:bg-rose-50 text-rose-800 px-12 py-5 rounded-full font-bold text-lg transition-all hover:shadow-2xl hover:scale-105">
          Book My Free Session
        </a>
      </div>
    </section>

    <!-- Location & Hours -->
    <section id="location" class="bg-[#FDF5F0] py-24" aria-labelledby="location-heading">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid md:grid-cols-2 gap-16">
          <div>
            <p class="text-rose-400 text-xs uppercase tracking-[0.4em] font-semibold mb-3">Visit Us</p>
            <h2 id="location-heading" class="font-playfair text-4xl font-bold text-rose-900 mb-8">Location &amp; Hours</h2>
            <address class="not-italic text-rose-700 mb-8 text-sm space-y-2">
              <p class="font-playfair text-xl font-bold text-rose-900">{coach.gym}</p>
              <p class="mt-2">{coach.address.street}</p>
              <p>{coach.address.city}</p>
              <p class="mt-3"><a href={`tel:${coach.phone.replace(/\D/g,'')}`} class="text-rose-600 hover:text-rose-800 transition-colors">{coach.phone}</a></p>
              <p><a href={`mailto:${coach.email}`} class="text-rose-600 hover:text-rose-800 transition-colors">{coach.email}</a></p>
            </address>
            <h3 class="font-playfair font-bold text-rose-900 text-xl mb-4">Studio Hours</h3>
            <table class="w-full text-sm" aria-label="Studio hours">
              <tbody>
                {coach.hours.map(h => (
                  <tr class="border-b border-rose-100">
                    <td class="py-3 text-rose-800 font-medium">{h.day}</td>
                    <td class="py-3 text-right text-rose-500">{h.hours}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <div class="relative">
            <img
              src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?auto=format&fit=crop&w=600&q=80"
              alt="Women working out together in the Fierce and Free studio"
              class="w-full aspect-video object-cover rounded-3xl"
            />
            <div class="mt-4 bg-white rounded-2xl p-6 border border-rose-100">
              <p class="font-playfair font-bold text-rose-900">Women-only training space</p>
              <p class="text-rose-500 text-sm mt-1">A safe, supportive environment designed entirely for women — from the equipment to the energy in the room.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Booking Form -->
    <section id="booking" class="bg-rose-50 py-24" aria-labelledby="booking-heading">
      <div class="max-w-2xl mx-auto px-6">
        <div class="text-center mb-12">
          <p class="text-rose-400 text-xs uppercase tracking-[0.4em] font-semibold mb-3">Ready to Begin?</p>
          <h2 id="booking-heading" class="font-playfair text-5xl font-bold text-rose-900">Book your free intro</h2>
          <p class="text-rose-500 mt-4">Amanda personally reviews every submission. You'll hear back within 24 hours.</p>
        </div>
        <form class="space-y-5 bg-white rounded-3xl p-8 shadow-sm border border-rose-100" aria-label="Free intro booking form" novalidate>
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="v3-name" class="block text-rose-800 text-sm font-semibold mb-2">Full Name <span class="text-red-400" aria-label="required">*</span></label>
              <input type="text" id="v3-name" name="name" required autocomplete="name" placeholder="Your name"
                class="w-full border border-rose-200 text-rose-900 px-4 py-3 rounded-xl focus:border-rose-400 focus:ring-2 focus:ring-rose-100 focus:outline-none transition-all placeholder:text-rose-200 text-sm" />
            </div>
            <div>
              <label for="v3-email" class="block text-rose-800 text-sm font-semibold mb-2">Email <span class="text-red-400" aria-label="required">*</span></label>
              <input type="email" id="v3-email" name="email" required autocomplete="email" placeholder="you@example.com"
                class="w-full border border-rose-200 text-rose-900 px-4 py-3 rounded-xl focus:border-rose-400 focus:ring-2 focus:ring-rose-100 focus:outline-none transition-all placeholder:text-rose-200 text-sm" />
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="v3-phone" class="block text-rose-800 text-sm font-semibold mb-2">Phone</label>
              <input type="tel" id="v3-phone" name="phone" autocomplete="tel" placeholder="(512) 555-0000"
                class="w-full border border-rose-200 text-rose-900 px-4 py-3 rounded-xl focus:border-rose-400 focus:ring-2 focus:ring-rose-100 focus:outline-none transition-all placeholder:text-rose-200 text-sm" />
            </div>
            <div>
              <label for="v3-goal" class="block text-rose-800 text-sm font-semibold mb-2">Your Goal <span class="text-red-400" aria-label="required">*</span></label>
              <select id="v3-goal" name="goal" required
                class="w-full border border-rose-200 text-rose-900 px-4 py-3 rounded-xl focus:border-rose-400 focus:ring-2 focus:ring-rose-100 focus:outline-none transition-all text-sm bg-white">
                <option value="">Choose a goal</option>
                <option value="strength">Build strength &amp; confidence</option>
                <option value="fat-loss">Lose weight sustainably</option>
                <option value="postnatal">Postnatal recovery</option>
                <option value="hormones">Hormone health &amp; energy</option>
                <option value="community">Find a supportive community</option>
              </select>
            </div>
          </div>
          <div>
            <label for="v3-experience" class="block text-rose-800 text-sm font-semibold mb-2">Training background</label>
            <select id="v3-experience" name="experience"
              class="w-full border border-rose-200 text-rose-900 px-4 py-3 rounded-xl focus:border-rose-400 focus:ring-2 focus:ring-rose-100 focus:outline-none transition-all text-sm bg-white">
              <option value="none">Complete beginner</option>
              <option value="some">Some experience</option>
              <option value="returning">Returning after a break</option>
              <option value="experienced">Experienced lifter</option>
            </select>
          </div>
          <div>
            <label for="v3-message" class="block text-rose-800 text-sm font-semibold mb-2">Share your story</label>
            <textarea id="v3-message" name="message" rows="4" placeholder="Where are you in your journey? What's holding you back? What do you dream of achieving?"
              class="w-full border border-rose-200 text-rose-900 px-4 py-3 rounded-xl focus:border-rose-400 focus:ring-2 focus:ring-rose-100 focus:outline-none transition-all placeholder:text-rose-200 resize-none text-sm"></textarea>
          </div>
          <button type="submit" class="w-full bg-rose-700 hover:bg-rose-800 text-white py-4 rounded-full font-bold text-lg transition-all hover:shadow-lg hover:shadow-rose-200">
            Book My Free Session
          </button>
          <p class="text-center text-rose-300 text-xs">All women welcome. No judgment, no pressure — just support.</p>
        </form>
      </div>
    </section>
  </main>

  <footer class="bg-rose-900 py-12">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <p class="font-playfair text-white text-xl font-bold">{coach.gym}</p>
      <p class="text-rose-400 text-xs mt-2">© {new Date().getFullYear()} {coach.gym}. All rights reserved.</p>
      <p class="text-rose-700 text-xs mt-2"><a href="/" class="hover:text-rose-400 transition-colors">← All Templates</a></p>
    </div>
  </footer>
</BaseLayout>
